   <cls:CL_FP_CODING id="o5">
    <CL_FP_INTERFACE_DATA_CHANGED classVersion="1">
     <INTERFACE_DATA href="#o1"/>
    </CL_FP_INTERFACE_DATA_CHANGED>
    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS>
      <FPPARAMETER>WA_FINAL</FPPARAMETER>
      <FPPARAMETER>LV_TOTAL_AMT</FPPARAMETER>
      <FPPARAMETER>LV_CGST_TOT</FPPARAMETER>
      <FPPARAMETER>LV_SGST_TOT</FPPARAMETER>
      <FPPARAMETER>LV_IGST_TOT</FPPARAMETER>
      <FPPARAMETER>LV_TOTAL_QTY</FPPARAMETER>
      <FPPARAMETER>LV_PF</FPPARAMETER>
      <FPPARAMETER>LV_ZIN1</FPPARAMETER>
      <FPPARAMETER>LV_ZFR1</FPPARAMETER>
      <FPPARAMETER>LV_ZTE1</FPPARAMETER>
      <FPPARAMETER>LV_ZTCS</FPPARAMETER>
      <FPPARAMETER>LV_STATE_AG</FPPARAMETER>
      <FPPARAMETER>LV_STATE_WE</FPPARAMETER>
      <FPPARAMETER>LV_VBELN</FPPARAMETER>
      <FPPARAMETER>LV_NAME</FPPARAMETER>
      <FPPARAMETER>LT_LINES</FPPARAMETER>
      <FPPARAMETER>LS_LINES</FPPARAMETER>
     </INPUT_PARAMETERS>
     <OUTPUT_PARAMETERS>
      <FPPARAMETER>LS_ADRC_AG</FPPARAMETER>
      <FPPARAMETER>LS_ADRC_WE</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE/>
      <FPCLINE>CLEAR: wa_final ,lv_total_amt, lv_cgst_tot,</FPCLINE>
      <FPCLINE>       lv_sgst_tot,lv_igst_tot,lv_total_qty,</FPCLINE>
      <FPCLINE>       lv_pf,lv_zin1,lv_zfr1,lv_zte1,lv_ztcs.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>data : IT_FINAL TYPE TABLE OF ZSALESORDER_STR.</FPCLINE>
      <FPCLINE>*       WA_FINAL TYPE ZSALESORDER_STR.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>READ TABLE it_final INTO data(wa_final) INDEX 1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT adrnr,parvw  FROM vbpa</FPCLINE>
      <FPCLINE> INTO TABLE @DATA(lt_vbpa)</FPCLINE>
      <FPCLINE>  WHERE vbeln = @LV_VBELN&quot;@wa_final-vbeln</FPCLINE>
      <FPCLINE>  AND      posnr = &apos; &apos;</FPCLINE>
      <FPCLINE>  AND ( parvw = &apos;AG&apos; OR parvw = &apos;WE&apos; ).</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF lt_vbpa IS NOT INITIAL.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  LOOP AT lt_vbpa ASSIGNING FIELD-SYMBOL(&lt;f1&gt;).</FPCLINE>
      <FPCLINE/>
      <FPCLINE>    CASE &lt;f1&gt;-parvw.</FPCLINE>
      <FPCLINE>      WHEN &apos;AG&apos;.</FPCLINE>
      <FPCLINE>        SELECT SINGLE * FROM adrc INTO ls_adrc_ag</FPCLINE>
      <FPCLINE>       WHERE addrnumber = &lt;f1&gt;-adrnr.</FPCLINE>
      <FPCLINE>        IF ls_adrc_AG-COUNTRY = &apos;IN&apos; .</FPCLINE>
      <FPCLINE>         SELECT SINGLE bezei FROM zgst_region1</FPCLINE>
      <FPCLINE>           INTO lv_state_ag</FPCLINE>
      <FPCLINE>           WHERE region = ls_adrc_AG-region.</FPCLINE>
      <FPCLINE>         ENDIF.</FPCLINE>
      <FPCLINE>      WHEN &apos;WE&apos;.</FPCLINE>
      <FPCLINE>        SELECT SINGLE * FROM adrc INTO ls_adrc_we</FPCLINE>
      <FPCLINE>              WHERE addrnumber = &lt;f1&gt;-adrnr.</FPCLINE>
      <FPCLINE>        IF ls_adrc_we-COUNTRY = &apos;IN&apos; .</FPCLINE>
      <FPCLINE>           SELECT SINGLE bezei FROM zgst_region1</FPCLINE>
      <FPCLINE>           INTO lv_state_we</FPCLINE>
      <FPCLINE>           WHERE region = ls_adrc_we-region.</FPCLINE>
      <FPCLINE>        ENDIF.</FPCLINE>
      <FPCLINE>      WHEN OTHERS.</FPCLINE>
      <FPCLINE>    ENDCASE.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  ENDLOOP.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CLEAR WA_FINAL.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*---------------------------------------------------------*</FPCLINE>
      <FPCLINE>lv_name = lv_vbeln.</FPCLINE>
      <FPCLINE>CALL FUNCTION &apos;READ_TEXT&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>   CLIENT                        = SY-MANDT</FPCLINE>
      <FPCLINE>    id                            = &apos;Z020&apos;</FPCLINE>
      <FPCLINE>    language                      = sy-langu</FPCLINE>
      <FPCLINE>    NAME                          = lv_name</FPCLINE>
      <FPCLINE>    OBJECT                        = &apos;VBBK&apos;</FPCLINE>
      <FPCLINE>*   ARCHIVE_HANDLE                = 0</FPCLINE>
      <FPCLINE>*   LOCAL_CAT                     = &apos; &apos;</FPCLINE>
      <FPCLINE>* IMPORTING</FPCLINE>
      <FPCLINE>*   HEADER                        =</FPCLINE>
      <FPCLINE>*   OLD_LINE_COUNTER              =</FPCLINE>
      <FPCLINE>  TABLES</FPCLINE>
      <FPCLINE>    lines                         = lt_lines</FPCLINE>
      <FPCLINE> EXCEPTIONS</FPCLINE>
      <FPCLINE>  ID                            = 1</FPCLINE>
      <FPCLINE>   LANGUAGE                      = 2</FPCLINE>
      <FPCLINE>   NAME                          = 3</FPCLINE>
      <FPCLINE>   NOT_FOUND                     = 4</FPCLINE>
      <FPCLINE>   OBJECT                        = 5</FPCLINE>
      <FPCLINE>   REFERENCE_CHECK               = 6</FPCLINE>
      <FPCLINE>   WRONG_ACCESS_TO_ARCHIVE       = 7</FPCLINE>
      <FPCLINE>   OTHERS                        = 8 .</FPCLINE>
      <FPCLINE>IF sy-subrc &lt;&gt; 0.</FPCLINE>
      <FPCLINE>* Implement suitable error handling here</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*---------------------------------------------------------*</FPCLINE>
     </INITIALIZATION>
     <FORMS/>
