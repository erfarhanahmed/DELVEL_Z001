FORM F4_FILEPATH USING FP_TYPE FP_PATH.
  CALL FUNCTION 'WS_FILENAME_GET'
       EXPORTING
*           DEF_FILENAME     = ' '
*           DEF_PATH         = ' '
            MASK             = ' ,*,*,*,*.'
            MODE             = '0'
*           TITLE            = ' '
       IMPORTING
            FILENAME         = FP_PATH
*           RC               = '
       EXCEPTIONS
            INV_WINSYS       = 1
            NO_BATCH         = 2
            SELECTION_CANCEL = 3
            SELECTION_ERROR  = 4
            OTHERS           = 5.

  IF SY-SUBRC <> 0.
* MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO
*         WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.
  ENDIF.

  CHECK FP_TYPE EQ '%DOWN'.
  CALL FUNCTION 'SO_SPLIT_FILE_AND_PATH'
    EXPORTING
      FULL_NAME     = FP_PATH
    IMPORTING
*     STRIPPED_NAME =
      FILE_PATH     = FP_PATH
    EXCEPTIONS
      X_ERROR       = 1
      OTHERS        = 2.

ENDFORM.                    " F4_FILEPATH
