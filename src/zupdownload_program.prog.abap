DEFINE GET_MENU.
  LOOP AT &2.
    CLEAR GT_PROGTEXT.
    CONCATENATE &1 &2 INTO GT_PROGTEXT-TEXT.
    APPEND GT_PROGTEXT.
  ENDLOOP.
END-OF-DEFINITION.

DEFINE SET_MENU.
  CLEAR &1.
  WRITE GT_PROGTEXT+7 TO &1.
  APPEND &1.
END-OF-DEFINITION.

