      FORMAT: INTENSIFIED OFF, COLOR COL_HEADING.
      WRITE: /(80) 'Download Log'.
      FORMAT: INTENSIFIED OFF, COLOR COL_NORMAL.
      WRITE: / C_HYPHEN,
             /03 'Download path    :', P_DPATH(59).

    WHEN 'TABS1' OR 'EXUP'.     "Upload
      FORMAT: INTENSIFIED OFF, COLOR COL_HEADING.
      WRITE: /(80) 'Upload Log'.
      FORMAT: INTENSIFIED OFF, COLOR COL_NORMAL.
      WRITE: / C_HYPHEN,
             /03 'Upload path      :', P_UPATH(59).
  ENDCASE.

ENDFORM.                    " WRITE_HEADER

