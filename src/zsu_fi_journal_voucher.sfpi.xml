     <INITIALIZATION>
      <FPCLINE>CLEAR : wa_bseg,</FPCLINE>
      <FPCLINE>        wa_lfa1,</FPCLINE>
      <FPCLINE>        wa_kna1, wa_skat, wa_anla, gv_tot,gv_tot1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>select  bukrs</FPCLINE>
      <FPCLINE>        gjahr</FPCLINE>
      <FPCLINE>        belnr</FPCLINE>
      <FPCLINE>        koart</FPCLINE>
      <FPCLINE>        hkont</FPCLINE>
      <FPCLINE>        lifnr</FPCLINE>
      <FPCLINE>        kunnr</FPCLINE>
      <FPCLINE>        anln1</FPCLINE>
      <FPCLINE>        dmbtr</FPCLINE>
      <FPCLINE>        shkzg</FPCLINE>
      <FPCLINE>   from bseg</FPCLINE>
      <FPCLINE>   into table it_bseg</FPCLINE>
      <FPCLINE>  WHERE belnr = belnr</FPCLINE>
      <FPCLINE>    AND gjahr = gjahr</FPCLINE>
      <FPCLINE>    AND BUKRS = WA_FINAL1-BUKRS.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>wa_final = wa_final1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>DATA:str TYPE char255.</FPCLINE>
      <FPCLINE>str = &apos;شركة دلفال فلو كونترولز الشرق الأوسط المحدودة&apos;.</FPCLINE>
      <FPCLINE>CALL FUNCTION &apos;STRING_REVERSE&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    STRING          = str</FPCLINE>
      <FPCLINE>    LANG            = &apos;A&apos;</FPCLINE>
      <FPCLINE> IMPORTING</FPCLINE>
      <FPCLINE>   RSTRING         = lv_invno.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>*DATA:str TYPE char255.</FPCLINE>
      <FPCLINE>str = &apos;شركة دلفال فلو كونترولز الشرق الأوسط المحدودة&apos;.</FPCLINE>
