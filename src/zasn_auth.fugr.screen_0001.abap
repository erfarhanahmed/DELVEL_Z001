    FIELD ZASN_AUTH-SUPPLIER .
    FIELD ZASN_AUTH-FIRSTNAME .
    FIELD ZASN_AUTH-LASTNAME .
    FIELD ZASN_AUTH-EMAIL .
    FIELD ZASN_AUTH-CNO .
    FIELD ZASN_AUTH-STATUS .
    FIELD ZASN_AUTH-CREATEDBY .
    FIELD ZASN_AUTH-CHANGEDBY .
    FIELD ZASN_AUTH-CREATEDDATE .
    FIELD ZASN_AUTH-CHANGEDDATE .
    FIELD ZASN_AUTH-VALIDFROM .
    FIELD ZASN_AUTH-VALIDTO .
    FIELD ZASN_AUTH-DELFLAG .
    MODULE SET_UPDATE_FLAG ON CHAIN-REQUEST.
   ENDCHAIN.
   FIELD VIM_MARKED MODULE LISTE_MARK_CHECKBOX.
   CHAIN.
    FIELD ZASN_AUTH-USERNAME .
