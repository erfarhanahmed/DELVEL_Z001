  CLEAR:LV_BFV,LV_ACT,LV_AUT,LV_DTO,LV_BLV,LV_COM,LV_AST,LV_PAC,LV_FST,LV_FMT,LV_CHK.

  SELECT  CANCELLED
          BWART
          LBBSA_SID
          EBELN
          LGORT
          BUDAT
          WERKS
          BUKRS
          MBLNR
          MJAHR
          UMLGO
          MATNR
    FROM MATDOC INTO TABLE IT_MATDOC
    WHERE CANCELLED <> 'X'
    AND BWART = '321'
    AND LBBSA_SID = '02'
    AND EBELN <> SPACE
    AND UMLGO NOT IN ( 'KSRN', 'SRN1', 'KRWK', 'RWK1', 'KSCR', 'SCR1', 'KRJ0', 'RJ01' )
    AND BUDAT IN S_BUDAT
    AND WERKS IN P_WERKS
    AND BUKRS IN P_BUKRS.

  SORT IT_MATDOC BY BUDAT.

  IF IT_MATDOC IS NOT INITIAL.

    SELECT MATNR
               BRAND
          FROM MARA INTO TABLE IT_MARA
          FOR ALL ENTRIES IN IT_MATDOC
          WHERE MATNR = IT_MATDOC-MATNR.

    SELECT * FROM ZLOC_MAP INTO TABLE IT_ZLOC_MAP.

  ENDIF.

  SORT: IT_ZLOC_MAP BY STRG_LOC,
        IT_MARA BY MATNR.

  LOOP AT IT_MATDOC ASSIGNING FIELD-SYMBOL(<FS_MATDOC>).
    READ TABLE IT_ZLOC_MAP ASSIGNING FIELD-SYMBOL(<FS_LOC>)
     WITH KEY STRG_LOC = <FS_MATDOC>-UMLGO
     BINARY SEARCH.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_MARA ASSIGNING FIELD-SYMBOL(<FS_MARA>)
     WITH KEY MATNR = <FS_MATDOC>-MATNR
     BINARY SEARCH.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    LV_BRAND = <FS_MARA>-BRAND.
    LV_LOC   = <FS_LOC>-LOC_CODE.

    READ TABLE IT_FINAL1 INTO WA_FINAL1 WITH KEY PLANT = LV_LOC DATE = <FS_MATDOC>-BUDAT.

    IF SY-SUBRC <> 0.
      CLEAR WA_FINAL1.
      WA_FINAL1-PLANT = LV_LOC.
      WA_FINAL1-DATE  = <FS_MATDOC>-BUDAT.
      APPEND WA_FINAL1 TO IT_FINAL1.
      READ TABLE IT_FINAL1 INTO WA_FINAL1 INDEX SY-TABIX.
    ENDIF.

    CASE LV_BRAND.
      WHEN 'BFV'.
        WA_FINAL1-BFV = WA_FINAL1-BFV + 1.
        LV_BFV       = LV_BFV + 1.
      WHEN 'ACT'.
        WA_FINAL1-ACT = WA_FINAL1-ACT + 1.
        LV_ACT       = LV_ACT + 1.
      WHEN 'AUT'.
        WA_FINAL1-AUT = WA_FINAL1-AUT + 1.
        LV_AUT       = LV_AUT + 1.
      WHEN 'DTO'.
        WA_FINAL1-DTO = WA_FINAL1-DTO + 1.
        LV_DTO       = LV_DTO + 1.
      WHEN 'BLV'.
        WA_FINAL1-BLV = WA_FINAL1-BLV + 1.
        LV_BLV       = LV_BLV + 1.
      WHEN 'COM'.
        WA_FINAL1-COM = WA_FINAL1-COM + 1.
        LV_COM       = LV_COM + 1.
      WHEN 'AST'.
        WA_FINAL1-AST = WA_FINAL1-AST + 1.
        LV_AST       = LV_AST + 1.
      WHEN 'PAC'.
        WA_FINAL1-PAC = WA_FINAL1-PAC + 1.
        LV_PAC       = LV_PAC + 1.
      WHEN 'FST'.
        WA_FINAL1-FST = WA_FINAL1-FST + 1.
        LV_FST       = LV_FST + 1.
      WHEN 'FMT'.
        WA_FINAL1-FMT = WA_FINAL1-FMT + 1.
        LV_FMT       = LV_FMT + 1.
      WHEN 'CHK'.
        WA_FINAL1-CHK = WA_FINAL1-CHK + 1.
        LV_CHK       = LV_CHK + 1.
      WHEN 'NA'.
        WA_FINAL1-NA = WA_FINAL-NA + 1.
        LV_NA       = LV_NA + 1.
      WHEN OTHERS.
        CONTINUE.
    ENDCASE.

    WA_FINAL1-TOTAL = WA_FINAL1-BFV + WA_FINAL1-ACT + WA_FINAL1-AUT + WA_FINAL1-DTO + WA_FINAL1-BLV + WA_FINAL1-NA +
                     WA_FINAL1-COM + WA_FINAL1-AST + WA_FINAL1-PAC + WA_FINAL1-FST + WA_FINAL1-FMT + WA_FINAL1-CHK.

    MODIFY IT_FINAL1 FROM WA_FINAL1 INDEX SY-TABIX.

  ENDLOOP.

  CLEAR: WA_FINAL1.

ENDFORM.

