FORM UD_PENDING.
  REFRESH: IT_MATDOC,IT_QAMB,IT_QALS,IT_MARA,IT_ZLOC_MAP,IT_FINAL.
  CLEAR:LV_BFV,LV_ACT,LV_AUT,LV_DTO,LV_BLV,LV_COM,LV_AST,LV_PAC,LV_FST,LV_FMT,LV_CHK.

  SELECT CANCELLED
         BWART
         LBBSA_SID
         EBELN
         LGORT
         BUDAT
         WERKS
         BUKRS
         MBLNR
         MJAHR
         UMLGO
         MATNR
    FROM MATDOC INTO TABLE IT_MATDOC
    WHERE CANCELLED <> 'X'
    AND BWART = '101'
    AND LBBSA_SID = '02'
    AND EBELN <> SPACE
    AND LGORT <> SPACE
    AND BUDAT IN S_BUDAT
    AND WERKS IN P_WERKS
    AND BUKRS IN P_BUKRS.

  SELECT * FROM ZLOC_MAP INTO TABLE IT_ZLOC_MAP.

  IF IT_MATDOC IS NOT INITIAL.
    SELECT  PRUEFLOS
            MBLNR
            MJAHR
      FROM QAMB INTO TABLE IT_QAMB
      FOR ALL ENTRIES IN IT_MATDOC
      WHERE MBLNR EQ IT_MATDOC-MBLNR
      AND MJAHR EQ IT_MATDOC-MJAHR.

    IF IT_QAMB IS NOT INITIAL.
      SELECT PRUEFLOS
             STAT35
             MATNR
             LAGORTVORG
        FROM QALS INTO TABLE IT_QALS
        FOR ALL ENTRIES IN IT_QAMB
        WHERE PRUEFLOS EQ IT_QAMB-PRUEFLOS
        AND STAT35 NE 'X'.

      IF IT_QALS IS NOT INITIAL.
        SELECT MATNR
               BRAND
          FROM MARA INTO TABLE IT_MARA
          FOR ALL ENTRIES IN IT_QALS
          WHERE MATNR = IT_QALS-MATNR.


      ENDIF.
    ENDIF.
  ENDIF.

  LOOP AT IT_QALS ASSIGNING FIELD-SYMBOL(<FS_QALS>).
    READ TABLE IT_QAMB ASSIGNING FIELD-SYMBOL(<FS_QAMB>)
    WITH KEY PRUEFLOS = <FS_QALS>-PRUEFLOS.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_MATDOC ASSIGNING FIELD-SYMBOL(<FS_MATDOC>)
    WITH KEY MBLNR = <FS_QAMB>-MBLNR
             MJAHR = <FS_QAMB>-MJAHR.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_ZLOC_MAP ASSIGNING FIELD-SYMBOL(<FS_LOC>)
     WITH KEY STRG_LOC = <FS_QALS>-LAGORTVORG.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_MARA ASSIGNING FIELD-SYMBOL(<FS_MARA>)
     WITH KEY MATNR = <FS_QALS>-MATNR.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    LV_BRAND = <FS_MARA>-BRAND.
    LV_LOC   = <FS_LOC>-LOC_CODE.

    READ TABLE IT_FINAL INTO WA_FINAL WITH KEY PLANT = LV_LOC DATE = <FS_MATDOC>-BUDAT.

    IF SY-SUBRC <> 0.
      CLEAR WA_FINAL.
      WA_FINAL-PLANT = LV_LOC.
      WA_FINAL-DATE  = <FS_MATDOC>-BUDAT.
      APPEND WA_FINAL TO IT_FINAL.
      READ TABLE IT_FINAL INTO WA_FINAL INDEX SY-TABIX.
    ENDIF.

    CASE LV_BRAND.
      WHEN 'BFV'.
        WA_FINAL-BFV = WA_FINAL-BFV + 1.
        LV_BFV       = LV_BFV + 1.
      WHEN 'ACT'.
        WA_FINAL-ACT = WA_FINAL-ACT + 1.
        LV_ACT       = LV_ACT + 1.
      WHEN 'AUT'.
        WA_FINAL-AUT = WA_FINAL-AUT + 1.
        LV_AUT       = LV_AUT + 1.
      WHEN 'DTO'.
        WA_FINAL-DTO = WA_FINAL-DTO + 1.
        LV_DTO       = LV_DTO + 1.
      WHEN 'BLV'.
        WA_FINAL-BLV = WA_FINAL-BLV + 1.
        LV_BLV       = LV_BLV + 1.
      WHEN 'COM'.
        WA_FINAL-COM = WA_FINAL-COM + 1.
        LV_COM       = LV_COM + 1.
      WHEN 'AST'.
        WA_FINAL-AST = WA_FINAL-AST + 1.
        LV_AST       = LV_AST + 1.
      WHEN 'PAC'.
        WA_FINAL-PAC = WA_FINAL-PAC + 1.
        LV_PAC       = LV_PAC + 1.
      WHEN 'FST'.
        WA_FINAL-FST = WA_FINAL-FST + 1.
        LV_FST       = LV_FST + 1.
      WHEN 'FMT'.
        WA_FINAL-FMT = WA_FINAL-FMT + 1.
        LV_FMT       = LV_FMT + 1.
      WHEN 'CHK'.
        WA_FINAL-CHK = WA_FINAL-CHK + 1.
        LV_CHK       = LV_CHK + 1.
      WHEN 'NA'.
        WA_FINAL-NA = WA_FINAL-NA + 1.
        LV_NA       = LV_NA + 1.
      WHEN OTHERS.
        CONTINUE.
    ENDCASE.

    WA_FINAL-TOTAL = WA_FINAL-BFV + WA_FINAL-ACT + WA_FINAL-AUT + WA_FINAL-DTO + WA_FINAL-BLV + WA_FINAL-NA +
                     WA_FINAL-COM + WA_FINAL-AST + WA_FINAL-PAC + WA_FINAL-FST + WA_FINAL-FMT + WA_FINAL-CHK.

    MODIFY IT_FINAL FROM WA_FINAL INDEX SY-TABIX.

  ENDLOOP.

  CLEAR: WA_FINAL.

ENDFORM.


FORM UD_DONE_A.
