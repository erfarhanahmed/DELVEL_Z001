  SELECT CANCELLED
         BWART
         LBBSA_SID
         EBELN
         LGORT
         BUDAT
         WERKS
         BUKRS
         MBLNR
         MJAHR
         UMLGO
         MATNR
    FROM MATDOC INTO TABLE IT_MATDOC
    WHERE CANCELLED <> 'X'
    AND BWART = '321'
    AND EBELN <> SPACE
    AND LGORT IN ( 'KSCR', 'SCR1' )
    AND BUDAT IN S_BUDAT
    AND WERKS IN P_WERKS
    AND BUKRS IN P_BUKRS.

  IF IT_MATDOC IS NOT INITIAL.
    SELECT PRUEFLOS
           MBLNR
           MJAHR
      FROM QAMB INTO TABLE IT_QAMB
      FOR ALL ENTRIES IN IT_MATDOC
      WHERE MBLNR EQ IT_MATDOC-MBLNR
      AND MJAHR EQ IT_MATDOC-MJAHR.

    IF IT_QAMB IS NOT INITIAL.
      SELECT PRUEFLOS
             STAT35
             MATNR
             LAGORTVORG
        FROM QALS INTO TABLE IT_QALS
        FOR ALL ENTRIES IN IT_QAMB
        WHERE PRUEFLOS EQ IT_QAMB-PRUEFLOS
        AND STAT35 EQ 'X'.

      IF IT_QALS IS NOT INITIAL.
        SELECT MATNR
               BRAND
          FROM MARA INTO TABLE IT_MARA
          FOR ALL ENTRIES IN IT_QALS
          WHERE MATNR = IT_QALS-MATNR.

        SELECT * FROM ZLOC_MAP INTO TABLE IT_ZLOC_MAP.

      ENDIF.
    ENDIF.
  ENDIF.

  LOOP AT IT_QALS ASSIGNING FIELD-SYMBOL(<FS_QALS>).

    READ TABLE IT_ZLOC_MAP ASSIGNING FIELD-SYMBOL(<FS_LOC>)
     WITH KEY STRG_LOC = <FS_QALS>-LAGORTVORG.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_MARA ASSIGNING FIELD-SYMBOL(<FS_MARA>)
     WITH KEY MATNR = <FS_QALS>-MATNR.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_QAMB ASSIGNING FIELD-SYMBOL(<FS_QAMB>)
    WITH KEY PRUEFLOS = <FS_QALS>-PRUEFLOS.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    READ TABLE IT_MATDOC ASSIGNING FIELD-SYMBOL(<FS_MATDOC>)
    WITH KEY MBLNR = <FS_QAMB>-MBLNR
             MJAHR = <FS_QAMB>-MJAHR.
    IF SY-SUBRC <> 0.
      CONTINUE.
    ENDIF.

    LV_BRAND = <FS_MARA>-BRAND.
    LV_LOC   = <FS_LOC>-LOC_CODE.

    READ TABLE IT_FINAL5 INTO WA_FINAL5 WITH KEY PLANT = LV_LOC DATE = <FS_MATDOC>-BUDAT.

    IF SY-SUBRC <> 0.
      CLEAR WA_FINAL5.
      WA_FINAL5-PLANT = LV_LOC.
      WA_FINAL5-DATE  = <FS_MATDOC>-BUDAT.
      APPEND WA_FINAL5 TO IT_FINAL5.
      READ TABLE IT_FINAL5 INTO WA_FINAL5 INDEX SY-TABIX.
    ENDIF.

    CASE LV_BRAND.
      WHEN 'BFV'.
        WA_FINAL5-BFV = WA_FINAL5-BFV + 1.
        LV_BFV       = LV_BFV + 1.
      WHEN 'ACT'.
        WA_FINAL5-ACT = WA_FINAL5-ACT + 1.
        LV_ACT       = LV_ACT + 1.
      WHEN 'AUT'.
        WA_FINAL5-AUT = WA_FINAL5-AUT + 1.
        LV_AUT       = LV_AUT + 1.
      WHEN 'DTO'.
        WA_FINAL5-DTO = WA_FINAL5-DTO + 1.
        LV_DTO       = LV_DTO + 1.
      WHEN 'BLV'.
        WA_FINAL5-BLV = WA_FINAL5-BLV + 1.
        LV_BLV       = LV_BLV + 1.
      WHEN 'COM'.
        WA_FINAL5-COM = WA_FINAL5-COM + 1.
        LV_COM       = LV_COM + 1.
      WHEN 'AST'.
        WA_FINAL5-AST = WA_FINAL5-AST + 1.
        LV_AST       = LV_AST + 1.
      WHEN 'PAC'.
        WA_FINAL5-PAC = WA_FINAL5-PAC + 1.
        LV_PAC       = LV_PAC + 1.
      WHEN 'FST'.
        WA_FINAL5-FST = WA_FINAL5-FST + 1.
        LV_FST       = LV_FST + 1.
      WHEN 'FMT'.
        WA_FINAL5-FMT = WA_FINAL5-FMT + 1.
        LV_FMT       = LV_FMT + 1.
      WHEN 'CHK'.
        WA_FINAL5-CHK = WA_FINAL5-CHK + 1.
        LV_CHK       = LV_CHK + 1.
      WHEN 'NA'.
        WA_FINAL5-NA = WA_FINAL-NA + 1.
        LV_NA       = LV_NA + 1.
      WHEN OTHERS.
        CONTINUE.
    ENDCASE.

    WA_FINAL5-TOTAL = WA_FINAL5-BFV + WA_FINAL5-ACT + WA_FINAL5-AUT + WA_FINAL5-DTO + WA_FINAL5-BLV + WA_FINAL5-NA +
                     WA_FINAL5-COM + WA_FINAL5-AST + WA_FINAL5-PAC + WA_FINAL5-FST + WA_FINAL5-FMT + WA_FINAL5-CHK.

    MODIFY IT_FINAL5 FROM WA_FINAL5 INDEX SY-TABIX.

  ENDLOOP.

  CLEAR: WA_FINAL5.

ENDFORM.
