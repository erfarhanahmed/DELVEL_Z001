      <FPCLINE>*BREAK X770202.</FPCLINE>
      <FPCLINE>LOOP AT lt_bset INTO ls_bset.</FPCLINE>
      <FPCLINE>  CASE ls_bset-kschl.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>    WHEN &apos;MWAS&apos;.</FPCLINE>
