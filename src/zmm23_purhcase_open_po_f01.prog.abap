FORM ADD_FIELD USING
      P_FIELDNAME TYPE STRING
      P_COLTEXT   TYPE STRING.

  CLEAR GS_DYN_FCAT.

  GS_DYN_FCAT-FIELDNAME = P_FIELDNAME.
  GS_DYN_FCAT-COLTEXT   = P_COLTEXT.
  GS_DYN_FCAT-SCRTEXT_L = P_COLTEXT.
  GS_DYN_FCAT-SCRTEXT_M = P_COLTEXT.
  GS_DYN_FCAT-SCRTEXT_S = P_COLTEXT.
  GS_DYN_FCAT-OUTPUTLEN = 20.
*  GS_DYN_FCAT-CWIDTH_OPT = ABAP_TRUE.

  APPEND GS_DYN_FCAT TO GT_DYN_FCAT.
  CLEAR WA_FIELDCAT.
  IF P_COLTEXT CS 'VAL'.
    WA_FIELDCAT-DATATYPE   = 'DEC'.
*    WA_FIELDCAT-CFIELDNAME = 'DMBTR'.
    WA_FIELDCAT-DECIMALS_OUT = 2.
  ENDIF.
  WA_FIELDCAT-FIELDNAME = P_FIELDNAME.
  WA_FIELDCAT-SELTEXT_L = P_COLTEXT.
  WA_FIELDCAT-OUTPUTLEN = 15.
  APPEND WA_FIELDCAT TO IT_FIELDCAT.

ENDFORM.

