CLASS CL_DATA IMPLEMENTATION.
  METHOD: GET_DATA.

    SELECT EKGRP VNAME FROM ZVERTICAL_MAP
      INTO TABLE IT_VERT_MAP
      WHERE VNAME IN S_VNAME.

    SELECT * FROM ZLOC_MAP INTO TABLE IT_ZLOC_MAP.

    IF IT_VERT_MAP IS NOT INITIAL.
      SELECT PURCHASEORDER,
             SUPPLIER,
             PURCHASINGGROUP
        FROM I_PURCHASEORDERAPI01
        INTO TABLE @IT_HEADER
        FOR ALL ENTRIES IN @IT_VERT_MAP
        WHERE SUPPLIER IN @S_LIFNR
        AND PURCHASINGGROUP EQ @IT_VERT_MAP-EKGRP.

      IF IT_HEADER IS NOT INITIAL.

        SELECT PURCHASEORDER,
               PURCHASEORDERITEM,
               MATERIALGROUP,
               MATERIAL,
               PLANT,
               STORAGELOCATION,
               ISCOMPLETELYDELIVERED,
               NETPRICEAMOUNT,
               NETAMOUNT,
               ORDERQUANTITY
          FROM I_PURCHASEORDERITEMAPI01
          INTO TABLE @IT_ITEM
          FOR ALL ENTRIES IN @IT_HEADER
          WHERE PURCHASEORDER EQ @IT_HEADER-PURCHASEORDER
          AND ISCOMPLETELYDELIVERED NE 'X'
          AND ISRETURNSITEM NE 'X'
          AND PURCHASINGDOCUMENTDELETIONCODE EQ @SPACE
          AND PLANT IN @P_WERKS.

        IF IT_ITEM IS NOT INITIAL.

          REFRESH: S_DELIV[].

          S_DELIV-SIGN = 'I'.
          S_DELIV-OPTION = 'BT'.

          IF SY-DATUM+4(2) EQ '01'
            OR SY-DATUM+4(2) EQ '02'
            OR SY-DATUM+4(2) EQ '03'.

            S_DELIV-LOW = |{ SY-DATUM+0(4) - 1 }0401|.
            S_DELIV-HIGH = |{ SY-DATUM+0(4) }0331|.
          ELSE.
            S_DELIV-LOW = |{ SY-DATUM+0(4) }0401|.
            S_DELIV-HIGH = |{ SY-DATUM+0(4) + 1 }0331|.
          ENDIF.
          APPEND S_DELIV TO S_DELIV[].


          SELECT PURCHASEORDER,
                 PURCHASEORDERITEM,
                 SCHEDULELINEDELIVERYDATE,
                 SCHEDULELINEORDERQUANTITY,
                 ROUGHGOODSRECEIPTQTY
            FROM C_PURORDSCHEDULELINEDEX
            INTO TABLE @IT_ITEM_DATE
            FOR ALL ENTRIES IN @IT_ITEM
            WHERE PURCHASEORDER EQ @IT_ITEM-PURCHASEORDER
            AND PURCHASEORDERITEM EQ @IT_ITEM-PURCHASEORDERITEM.

          IF IT_ITEM_DATE IS NOT INITIAL.

            SELECT MATERIALGROUP,
                   MATERIALGROUPNAME
              FROM I_PRODUCTGROUPTEXT
              INTO TABLE @IT_T023T
              FOR ALL ENTRIES IN @IT_ITEM
              WHERE MATERIALGROUP = @IT_ITEM-MATERIALGROUP
              AND LANGUAGE = @SY-LANGU.

          ENDIF.

        ENDIF.

      ENDIF.

    ENDIF.

  ENDMETHOD.

  METHOD: FILTER_DATA.

    LV_FIRST_DAY_CURR_MONTH = SY-DATUM.
    LV_FIRST_DAY_CURR_MONTH+6(2) = '01'.

    LV_LAST_DAY_PREV_MONTH = LV_FIRST_DAY_CURR_MONTH - 1.
    DATA(LV_TEST) = LV_LAST_DAY_PREV_MONTH+0(6).

    SORT: IT_T023T BY MATERIALGROUP,
          IT_ITEM BY PURCHASEORDER PURCHASEORDERITEM,
          IT_ITEM_DATE BY PURCHASEORDER PURCHASEORDERITEM.

    TYPES: BEGIN OF TY_MONTH,
             YEAR  TYPE I,
             MONTH TYPE MONTH,
           END OF TY_MONTH.

    DATA: LT_MONTHS TYPE SORTED TABLE OF TY_MONTH
          WITH UNIQUE KEY YEAR MONTH.

    LOOP AT IT_ITEM_DATE ASSIGNING FIELD-SYMBOL(<FS_ITEM_DATE1>).
      DATA(LV_YEAR)  = <FS_ITEM_DATE1>-SCHEDULELINEDELIVERYDATE+0(4).
      DATA(LV_MONTH) = <FS_ITEM_DATE1>-SCHEDULELINEDELIVERYDATE+4(2).
      INSERT VALUE TY_MONTH( YEAR = LV_YEAR MONTH = LV_MONTH )
        INTO TABLE LT_MONTHS.
    ENDLOOP.

    PERFORM ADD_FIELD USING 'PLANT' 'Plant'.
    PERFORM ADD_FIELD USING 'MATERIALGROUPNAME' 'Material Group'.

    LV_MON1 = LV_LAST_DAY_PREV_MONTH+4(2).
    CALL FUNCTION 'IDWT_READ_MONTH_TEXT'
      EXPORTING
        MONTH = LV_MON1
        LANGU = SY-LANGU
      IMPORTING
        T247  = WA_T247.

    DATA(LV_SUFFI) = |{ WA_T247-KTX }-{ LV_LAST_DAY_PREV_MONTH+0(4) }|.
    DATA(LV_TILL_QTY) = |TILL_QTY_{ LV_LAST_DAY_PREV_MONTH+0(4) }{ LV_LAST_DAY_PREV_MONTH+4(2) }|.
    DATA(LV_TILL_QTY_TXT) = |TILL { LV_SUFFI } QANTITY|.
    DATA(LV_TILL_VAL) = |TILL_VAL_{ LV_LAST_DAY_PREV_MONTH+0(4) }{ LV_LAST_DAY_PREV_MONTH+4(2) }|.
    DATA(LV_TILL_VAL_TXT) = |TILL { LV_SUFFI } VALUE|.

    PERFORM ADD_FIELD USING LV_TILL_QTY LV_TILL_QTY_TXT.
    PERFORM ADD_FIELD USING LV_TILL_VAL LV_TILL_VAL_TXT.
    DATA : LV_MON_TXT TYPE STRING.
    DATA : LS_T247 TYPE T247.
    DATA :LV_SUFFIX  TYPE STRING,
          LV_QTY     TYPE STRING,
          LV_QTY_TXT TYPE STRING,
          LV_VAL     TYPE STRING,
          LV_VAL_TXT TYPE STRING.


    LOOP AT LT_MONTHS INTO DATA(LS_MONTH).

      DATA(LV_REQ_MON) = |{ LS_MONTH-YEAR }{ LS_MONTH-MONTH }|.
      IF LV_REQ_MON BETWEEN LV_FIRST_DAY_CURR_MONTH+0(6) AND S_DELIV-HIGH+0(6).

        CALL FUNCTION 'IDWT_READ_MONTH_TEXT'
          EXPORTING
            MONTH = LS_MONTH-MONTH
            LANGU = SY-LANGU
          IMPORTING
            T247  = LS_T247.

        LV_SUFFIX = |{ LS_T247-KTX }-{ LS_MONTH-YEAR }|.
        LV_QTY = |QTY_{ LS_MONTH-YEAR }{ LS_MONTH-MONTH }|.
        LV_QTY_TXT = |{ LV_SUFFIX } QANTITY|.
        LV_VAL = |VAL_{ LS_MONTH-YEAR }{ LS_MONTH-MONTH }|.
        LV_VAL_TXT = |{ LV_SUFFIX } VALUE|.

        PERFORM ADD_FIELD USING LV_QTY LV_QTY_TXT.

        PERFORM ADD_FIELD USING LV_VAL LV_VAL_TXT.

      ELSEIF S_DELIV-HIGH+0(6) LT LV_REQ_MON.

        CALL FUNCTION 'IDWT_READ_MONTH_TEXT'
          EXPORTING
            MONTH = LS_MONTH-MONTH
            LANGU = SY-LANGU
          IMPORTING
            T247  = LS_T247.

        LV_SUFFIX = |{ LS_T247-KTX }-{ LS_MONTH-YEAR }|.
        LV_QTY = |QTY_{ LS_MONTH-YEAR }{ LS_MONTH-MONTH }|.
        LV_QTY_TXT = |{ LV_SUFFIX } QANTITY|.
        LV_VAL = |VAL_{ LS_MONTH-YEAR }{ LS_MONTH-MONTH }|.
        LV_VAL_TXT = |{ LV_SUFFIX } VALUE|.

        PERFORM ADD_FIELD USING LV_QTY LV_QTY_TXT.

        PERFORM ADD_FIELD USING LV_VAL LV_VAL_TXT.

      ENDIF.

    ENDLOOP.

    DATA: LR_TABLE TYPE REF TO DATA,
          LR_LINE  TYPE REF TO DATA.
    FIELD-SYMBOLS: <GT_DYN> TYPE STANDARD TABLE,
                   <GS_DYN> TYPE ANY.

    CALL METHOD CL_ALV_TABLE_CREATE=>CREATE_DYNAMIC_TABLE
      EXPORTING
        IT_FIELDCATALOG = GT_DYN_FCAT
      IMPORTING
        EP_TABLE        = LR_TABLE.

    ASSIGN LR_TABLE->* TO <GT_DYN>.
    CREATE DATA LR_LINE LIKE LINE OF <GT_DYN>.
    ASSIGN LR_LINE->* TO <GS_DYN>.
    FIELD-SYMBOLS: <FS>        TYPE ANY,
                   <FS_MATGRP> TYPE ANY,
                   <FS_PLANT>  TYPE ANY.

    LOOP AT IT_ITEM INTO WA_ITEM.

      READ TABLE IT_ITEM_DATE ASSIGNING FIELD-SYMBOL(<FS_ITEM_DATE>)
          WITH KEY PURCHASEORDER = WA_ITEM-PURCHASEORDER
                   PURCHASEORDERITEM = WA_ITEM-PURCHASEORDERITEM
                   BINARY SEARCH.
      IF SY-SUBRC <> 0 OR <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY EQ <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY.
        CONTINUE.
      ENDIF.

      READ TABLE IT_T023T ASSIGNING FIELD-SYMBOL(<FS_T023T>)
          WITH KEY MATERIALGROUP = WA_ITEM-MATERIALGROUP
                   BINARY SEARCH.
      IF SY-SUBRC <> 0.
        CONTINUE.
      ENDIF.

      READ TABLE IT_ZLOC_MAP ASSIGNING FIELD-SYMBOL(<FS_LOC>)
        WITH KEY STRG_LOC = WA_ITEM-STORAGELOCATION
        .
      IF SY-SUBRC <> 0.
        CONTINUE.
      ENDIF.

      LV_LOC = <FS_LOC>-LOC_CODE.
      LV_MATERIALGROUP = WA_ITEM-MATERIALGROUP.
      LV_MATERIALGROUPNAME = <FS_T023T>-MATERIALGROUPNAME.

      DATA LV_FOUND TYPE ABAP_BOOL VALUE ABAP_FALSE.


      LOOP AT <GT_DYN> ASSIGNING <GS_DYN>.

        ASSIGN COMPONENT 'PLANT' OF STRUCTURE <GS_DYN> TO <FS_PLANT>.

        ASSIGN COMPONENT 'MATERIALGROUPNAME' OF STRUCTURE <GS_DYN> TO <FS_MATGRP>.

        IF <FS_PLANT> = LV_LOC AND <FS_MATGRP> = LV_MATERIALGROUPNAME.

          LV_FOUND = ABAP_TRUE.

          IF <FS_ITEM_DATE>-SCHEDULELINEDELIVERYDATE LE LV_LAST_DAY_PREV_MONTH.

            LV_TILL_QTY = |TILL_QTY_{ LV_LAST_DAY_PREV_MONTH+0(4) }{ LV_LAST_DAY_PREV_MONTH+4(2) }|.
            LV_TILL_VAL = |TILL_VAL_{ LV_LAST_DAY_PREV_MONTH+0(4) }{ LV_LAST_DAY_PREV_MONTH+4(2) }|.

            ASSIGN COMPONENT LV_TILL_QTY OF STRUCTURE <GS_DYN> TO <FS>.
            IF SY-SUBRC = 0.
*              <FS> = <FS> + WA_ITEM-ORDERQUANTITY.
              <FS> = <FS> + ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ).
            ENDIF.

            " 4. Update value
            ASSIGN COMPONENT LV_TILL_VAL OF STRUCTURE <GS_DYN> TO <FS>.
            IF SY-SUBRC = 0.
*              <FS> = <FS> + WA_ITEM-NETAMOUNT.
              <FS> = <FS> + ( ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ) * WA_ITEM-NETPRICEAMOUNT ).
            ENDIF.

          ELSE.

            " 1. Determine month & year from delivery date
            LV_MONTH = <FS_ITEM_DATE>-SCHEDULELINEDELIVERYDATE+4(2).
            LV_YEAR  = <FS_ITEM_DATE>-SCHEDULELINEDELIVERYDATE+0(4).

            " 2. Build dynamic field names
            DATA(LV_FIELD_QTY) = |QTY_{ LV_YEAR }{ LV_MONTH }|.
            DATA(LV_FIELD_VAL) = |VAL_{ LV_YEAR }{ LV_MONTH }|.

            " 3. Update quantity
            ASSIGN COMPONENT LV_FIELD_QTY OF STRUCTURE <GS_DYN> TO <FS>.
            IF SY-SUBRC = 0.
*              <FS> = <FS> + WA_ITEM-ORDERQUANTITY.
              <FS> = <FS> + ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ).
            ENDIF.

            " 4. Update value
            ASSIGN COMPONENT LV_FIELD_VAL OF STRUCTURE <GS_DYN> TO <FS>.
            IF SY-SUBRC = 0.
*              <FS> = <FS> + WA_ITEM-NETAMOUNT.
              <FS> = <FS> + ( ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ) * WA_ITEM-NETPRICEAMOUNT ).
            ENDIF.

          ENDIF.

          EXIT.

        ENDIF.

      ENDLOOP.

      IF LV_FOUND = ABAP_FALSE.
        APPEND INITIAL LINE TO <GT_DYN> ASSIGNING <GS_DYN>.

        ASSIGN COMPONENT 'PLANT' OF STRUCTURE <GS_DYN> TO <FS_PLANT>.
        <FS_PLANT> = LV_LOC.

        ASSIGN COMPONENT 'MATERIALGROUPNAME' OF STRUCTURE <GS_DYN> TO <FS_MATGRP>.
        <FS_MATGRP> = LV_MATERIALGROUPNAME.

        IF <FS_ITEM_DATE>-SCHEDULELINEDELIVERYDATE LE LV_LAST_DAY_PREV_MONTH.

          LV_TILL_QTY = |TILL_QTY_{ LV_LAST_DAY_PREV_MONTH+0(4) }{ LV_LAST_DAY_PREV_MONTH+4(2) }|.
          LV_TILL_VAL = |TILL_VAL_{ LV_LAST_DAY_PREV_MONTH+0(4) }{ LV_LAST_DAY_PREV_MONTH+4(2) }|.

          ASSIGN COMPONENT LV_TILL_QTY OF STRUCTURE <GS_DYN> TO <FS>.
          IF SY-SUBRC = 0.
*            <FS> = <FS> + WA_ITEM-ORDERQUANTITY.
            <FS> = <FS> + ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ).
          ENDIF.

          " 4. Update value
          ASSIGN COMPONENT LV_TILL_VAL OF STRUCTURE <GS_DYN> TO <FS>.
          IF SY-SUBRC = 0.
*            <FS> = <FS> + WA_ITEM-NETAMOUNT.
            <FS> = <FS> + ( ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ) * WA_ITEM-NETPRICEAMOUNT ).
          ENDIF.

        ELSE.

          " 1. Determine month & year from delivery date
          LV_MONTH = <FS_ITEM_DATE>-SCHEDULELINEDELIVERYDATE+4(2).
          LV_YEAR  = <FS_ITEM_DATE>-SCHEDULELINEDELIVERYDATE+0(4).

          " 2. Build dynamic field names
          LV_FIELD_QTY = |QTY_{ LV_YEAR }{ LV_MONTH }|.
          LV_FIELD_VAL = |VAL_{ LV_YEAR }{ LV_MONTH }|.

          " 3. Update quantity
          ASSIGN COMPONENT LV_FIELD_QTY OF STRUCTURE <GS_DYN> TO <FS>.
          IF SY-SUBRC = 0.
*            <FS> = <FS> + WA_ITEM-ORDERQUANTITY.
            <FS> = <FS> + ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ).
          ENDIF.

          " 4. Update value
          ASSIGN COMPONENT LV_FIELD_VAL OF STRUCTURE <GS_DYN> TO <FS>.
          IF SY-SUBRC = 0.
*            <FS> = <FS> + WA_ITEM-NETAMOUNT.
            <FS> = <FS> + ( ( <FS_ITEM_DATE>-SCHEDULELINEORDERQUANTITY - <FS_ITEM_DATE>-ROUGHGOODSRECEIPTQTY ) * WA_ITEM-NETPRICEAMOUNT ).
          ENDIF.

        ENDIF.

      ENDIF.

      CLEAR LV_FOUND.

    ENDLOOP.
    SORT <GT_DYN>.

