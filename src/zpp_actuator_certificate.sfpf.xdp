               <exData contentType="text/html" xliff:rid="A698CB58-F4BD-429E-9671-CA697B29BC18">
                  <body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/"><p style="font-weight:bold;letter-spacing:0in">LEAK TEST @ 6Kg/cm2(g)<span style="xfa-spacerun:yes"> </span><span style="font-weight:normal"><span style="xfa-spacerun:yes">                   </span>:-<span style="xfa-spacerun:yes">    </span>NO VISIBLE LEAKAGE OBSERVED</span></p><p style="letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="font-weight:bold;letter-spacing:0in">FUNCTIONAL TEST<span style="xfa-spacerun:yes"> </span><span style="font-weight:normal"><span style="xfa-spacerun:yes">                             </span>:-<span style="xfa-spacerun:yes">    </span>OPEN<span style="xfa-spacerun:yes">  </span>-<span style="xfa-spacerun:yes">  </span>CLOSE OPERATION CHECKED<span style="xfa-spacerun:yes">  </span>&amp;<span style="xfa-spacerun:yes">  </span>FOUND SATISFACTORY</span></p><p style="letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="font-weight:bold;letter-spacing:0in">VISUAL INSPECTION<span style="xfa-spacerun:yes"> </span><span style="font-weight:normal"><span style="xfa-spacerun:yes">                          </span>:-<span style="xfa-spacerun:yes">    </span>SATISFACTORY</span></p></body>
               </exData>
            </value>
