    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS>
      <FPPARAMETER>TOTAL_DEBIT</FPPARAMETER>
      <FPPARAMETER>TOTAL_CREDIT</FPPARAMETER>
      <FPPARAMETER>LV_STRING</FPPARAMETER>
     </INPUT_PARAMETERS>
     <OUTPUT_PARAMETERS>
      <FPPARAMETER>TOTAL_DEBIT</FPPARAMETER>
      <FPPARAMETER>TOTAL_CREDIT</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE/>
      <FPCLINE>LOOP AT IT_FINAL INTO WA_FINAL.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>ENDLOOP.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>LOOP AT IT_CUSTBAL INTO WA_CUSTBAL.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>TOTAL_DEBIT = 0.</FPCLINE>
      <FPCLINE>TOTAL_CREDIT = 0.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>IF WA_CUSTBAL-CLBAL LT 0.</FPCLINE>
      <FPCLINE>  WA_CUSTBAL-CLBAL = WA_CUSTBAL-CLBAL * -1.</FPCLINE>
      <FPCLINE>LV_DR_CR = &apos;Cr&apos;.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  LV_DR_CR = &apos;Dr&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_CUSTBAL-NAME1 WA_CUSTBAL-NAME2 INTO LV_ADDR1</FPCLINE>
      <FPCLINE>SEPARATED BY  SPACE.</FPCLINE>
      <FPCLINE>CONDENSE LV_ADDR1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_CUSTBAL-HOUSE_NUM1</FPCLINE>
      <FPCLINE> WA_CUSTBAL-STREET WA_CUSTBAL-Str_suppl1 INTO LV_ADDR2</FPCLINE>
      <FPCLINE> SEPARATED BY SPACE.</FPCLINE>
      <FPCLINE>CONDENSE LV_ADDR2.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_CUSTBAL-STR_SUPPL2 WA_CUSTBAL-STR_SUPPL3</FPCLINE>
      <FPCLINE>INTO LV_ADDR3 SEPARATED BY SPACE.</FPCLINE>
      <FPCLINE>CONDENSE LV_ADDR3.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_CUSTBAL-LOCATION WA_CUSTBAL-ORT01 &apos;-&apos;</FPCLINE>
      <FPCLINE>WA_CUSTBAL-PSTLZ INTO LV_ADDR4 SEPARATED BY SPACE.</FPCLINE>
      <FPCLINE>CONDENSE LV_ADDR4.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_CUSTBAL-BEZEI WA_CUSTBAL-LANDX INTO LV_ADDR5</FPCLINE>
      <FPCLINE>SEPARATED BY SPACE.</FPCLINE>
      <FPCLINE>CONDENSE LV_ADDR5.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  ENDLOOP.</FPCLINE>
     </INITIALIZATION>
