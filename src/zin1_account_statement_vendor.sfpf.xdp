            <draw h="168.275mm" name="Text6" w="7.625in" x="0mm">
               <ui>
                  <textEdit/>
               </ui>
               <value>
                  <exData contentType="text/html" xliff:rid="BF79BE64-FB90-4D67-A5FB-B5D2C1745561">
                     <body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/"><p style="font-size:10pt;letter-spacing:0in">Subject :- Balance Confirmation as on<span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField026962" xfa:embedMode="raw" xfa:embedType="uri"/></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">Dear Sir,</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">Your balance as on<span style="font-size:11pt"><span style="xfa-spacerun:yes"> </span></span><span xfa:embed="#floatingField009961" xfa:embedMode="raw" xfa:embedType="uri"/><span style="font-size:11pt"><span style="xfa-spacerun:yes"> </span></span>as per our Statement of Accounts is<span style="font-size:11pt"><span style="xfa-spacerun:yes"> </span></span><span style="font-size:11pt;font-weight:bold;text-decoration:underline"><span xfa:embed="#floatingField024464" xfa:embedMode="raw" xfa:embedType="uri"/></span><span style="font-size:11pt;font-weight:bold;text-decoration:underline"><span style="xfa-spacerun:yes"> </span></span><span style="font-size:11pt;font-weight:bold;text-decoration:underline"><span xfa:embed="#floatingField005705" xfa:embedMode="raw" xfa:embedType="uri"/></span><span style="font-size:11pt;font-weight:bold;text-decoration:underline"><span style="xfa-spacerun:yes"> </span></span><span style="font-size:11pt;font-weight:bold;text-decoration:underline"><span xfa:embed="#floatingField028145" xfa:embedMode="raw" xfa:embedType="uri"/></span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">We wish you to confirm the same by signing the statement given below. Please attatch your Statement of Accounts in case balance is not matching.</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">Please note that if no reply is received within a fortnight, the balance will then be assumed to have been accepted by you as shown above.</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">Your reply within the given period will be highly appreciated.</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">Thanking You</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">For<span style="font-size:12pt"><span style="xfa-spacerun:yes"> </span></span><span style="font-size:12pt;font-weight:bold">DELVAL FLOW CONTROLS PVT. LTD.</span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">This is system generated Balance Confirmation and hence does not require a Signature.</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in">________________________________________________________________________________________</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span><span style="font-size:10pt">For Suppliers use only</span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">We confirm the balance as on<span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField023281" xfa:embedMode="raw" xfa:embedType="uri"/> as per our books of accounts is<span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField016827" xfa:embedMode="raw" xfa:embedType="uri"/>________________________</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:10pt;font-weight:normal;text-decoration:none;letter-spacing:0in">Stamp &amp; Sign</p><p style="margin-right:56.7pt;margin-bottom:0pt;line-height:12pt;font-size:12pt;font-weight:normal;text-decoration:none;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span></p></body>
                  </exData>
               </value>
               <font baselineShift="0pt" size="11pt" typeface="Times New Roman" underline="1" weight="bold"/>
               <margin bottomInset="0.5mm" leftInset="0.5mm" rightInset="0.5mm" topInset="0.5mm"/>
               <para hAlign="justify" lineHeight="12.95pt" marginLeft="3.6pt" marginRight="0pt" spaceAbove="0pt" spaceBelow="8pt" textIndent="0pt"/>
            </draw>
            <?templateDesigner expand 1?></subform>
