CLASS CL_DATA IMPLEMENTATION.
  METHOD: GET_DATA.

    SELECT EKGRP VNAME FROM ZVERTICAL_MAP
      INTO TABLE IT_VERT_MAP
      WHERE VNAME IN S_VNAME.

*    SELECT * FROM ZLOC_MAP INTO TABLE IT_ZLOC_MAP.

    LOOP AT IT_VERT_MAP ASSIGNING FIELD-SYMBOL(<FS_MAP>).
      APPEND VALUE #( SIGN = 'I' OPTION = 'EQ' LOW = <FS_MAP>-EKGRP ) TO LR_EKGRP.
    ENDLOOP.

    LOOP AT S_GJAHR[] ASSIGNING FIELD-SYMBOL(<FS_G>).


      CONCATENATE <FS_G>-LOW  '0401' INTO LV_LOW.

      IF <FS_G>-HIGH IS NOT INITIAL.
        LV_NEXT = <FS_G>-HIGH + 1.
      ELSE.
        LV_NEXT = <FS_G>-LOW + 1.
      ENDIF.
      CONCATENATE LV_NEXT '0331' INTO LV_HIGH.

      S_BUDAT-SIGN   = 'I'.
      S_BUDAT-OPTION = 'BT'.
      S_BUDAT-LOW    = LV_LOW.
      S_BUDAT-HIGH   = LV_HIGH.

      APPEND S_BUDAT TO S_BUDAT[].

    ENDLOOP.

    SELECT M~MATERIALDOCUMENTYEAR,
           M~MATERIALDOCUMENT,
           M~MATERIALDOCUMENTITEM,
           M~PURCHASEORDER,
           M~PURCHASEORDERITEM,
           M~PLANT,
           M~STORAGELOCATION,
           M~SUPPLIER,
           M~GOODSMOVEMENTTYPE,
           M~GOODSMOVEMENTISCANCELLED,
           M~POSTINGDATE,
           M~QUANTITYINBASEUNIT,
           M~MATERIAL,
           M~TOTALGOODSMVTAMTINCCCRCY
     FROM I_MATERIALDOCUMENTITEM_2 AS M
     INNER JOIN I_PURCHASEORDERAPI01 AS E
     ON E~PURCHASEORDER = M~PURCHASEORDER
     INTO TABLE @IT_MATDOC
     WHERE M~GOODSMOVEMENTTYPE = '101'
     AND M~GOODSMOVEMENTISCANCELLED <> 'X'
     AND M~PURCHASEORDER <> @SPACE
     AND M~PLANT = @P_WERKS
"     AND M~MATERIALDOCUMENTYEAR IN @S_GJAHR
*     AND M~POSTINGDATE IN @S_BUDAT
     AND M~SUPPLIER IN @S_LIFNR
     AND E~PURCHASINGGROUP IN @LR_EKGRP.



    IF IT_MATDOC IS NOT INITIAL.
      IT_MATDOC1 = IT_MATDOC.
      DELETE IT_MATDOC1 WHERE MATERIAL EQ SPACE.

      SELECT PRODUCT,
        PRODUCTGROUP
        FROM I_PRODUCT
        INTO TABLE @IT_MARA
        FOR ALL ENTRIES IN @IT_MATDOC1
        WHERE PRODUCT EQ @IT_MATDOC1-MATERIAL.

      IF IT_MARA IS NOT INITIAL.
        SELECT MATERIALGROUP,
             MATERIALGROUPNAME
        FROM I_PRODUCTGROUPTEXT
        INTO TABLE @IT_T023_MARA
        FOR ALL ENTRIES IN @IT_MARA
        WHERE MATERIALGROUP = @IT_MARA-PRODUCTGROUP
        AND LANGUAGE = @SY-LANGU.

      ENDIF.


      IT_MATDOC1 = IT_MATDOC.
      DELETE IT_MATDOC1 WHERE MATERIAL NE SPACE.

      IF IT_MATDOC1 IS NOT INITIAL.

        SELECT PURCHASEORDER,
             PURCHASEORDERITEM,
             MATERIALGROUP
          FROM I_PURCHASEORDERITEMAPI01
          INTO TABLE @IT_EKPO
          FOR ALL ENTRIES IN @IT_MATDOC1
          WHERE PURCHASEORDER     = @IT_MATDOC1-PURCHASEORDER
          AND PURCHASEORDERITEM = @IT_MATDOC1-PURCHASEORDERITEM.

        IF IT_EKPO IS NOT INITIAL.
          SELECT MATERIALGROUP,
                 MATERIALGROUPNAME
            FROM I_PRODUCTGROUPTEXT
            INTO TABLE @IT_T023_EKPO
            FOR ALL ENTRIES IN @IT_EKPO
            WHERE MATERIALGROUP = @IT_EKPO-MATERIALGROUP
            AND LANGUAGE = @SY-LANGU.
        ENDIF.


      ENDIF.

    ENDIF.


  ENDMETHOD.

  METHOD: FILTER_DATA.


    SORT IT_MATDOC BY POSTINGDATE.

    DATA(LV_MIN_DATE) = IT_MATDOC[ 1 ]-POSTINGDATE.
    DATA(LV_MAX_DATE) = IT_MATDOC[ LINES( IT_MATDOC ) ]-POSTINGDATE.

    DATA(LV_START_FY) = COND GJAHR(
      WHEN LV_MIN_DATE+4(2) >= '04'
      THEN LV_MIN_DATE(4)
      ELSE LV_MIN_DATE(4) - 1 ).

    DATA(LV_END_FY) = COND GJAHR(
      WHEN LV_MAX_DATE+4(2) >= '04'
      THEN LV_MAX_DATE(4)
      ELSE LV_MAX_DATE(4) - 1 ).

    DATA(LV_FY) = LV_START_FY.

    WHILE LV_FY <= LV_END_FY.

      DATA(LV_FY_START) = |{ LV_FY }0401|.
      DATA(LV_FY_END)   = |{ LV_FY + 1 }0331|.

      LV_QTY_SUM  = 0.
      LV_AMT_SUM  = 0.

      LOOP AT IT_MATDOC ASSIGNING FIELD-SYMBOL(<FS_MAT>)
        WHERE POSTINGDATE >= LV_FY_START
          AND POSTINGDATE <= LV_FY_END.

        LV_QTY_SUM = LV_QTY_SUM + <FS_MAT>-QUANTITYINBASEUNIT.
        LV_AMT_SUM = LV_AMT_SUM + <FS_MAT>-TOTALGOODSMVTAMTINCCCRCY.
      ENDLOOP.

      "--- Append only if data exists
      IF LV_QTY_SUM <> 0 OR LV_AMT_SUM <> 0.
        WA_FINAL2-FISCAL_YEAR = LV_FY.
        WA_FINAL2-QTY_SUM     = LV_QTY_SUM.
        WA_FINAL2-AMT_SUM     = LV_AMT_SUM.
        APPEND WA_FINAL2 TO IT_FINAL2.
      ENDIF.

      LV_FY = LV_FY + 1.
    ENDWHILE.




  ENDMETHOD.

  METHOD: DISPLAY_DATA.

    PERFORM GET_FCAT1.


    CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'
      EXPORTING
*       I_INTERFACE_CHECK       = ' '
*       I_BYPASSING_BUFFER      = ' '
*       I_BUFFER_ACTIVE         = ' '
        I_CALLBACK_PROGRAM      = SY-CPROG
*       I_CALLBACK_PF_STATUS_SET          = ' '
        I_CALLBACK_USER_COMMAND = 'USER_COMMAND'
*       I_CALLBACK_TOP_OF_PAGE  = ' '
*       I_CALLBACK_HTML_TOP_OF_PAGE       = ' '
*       I_CALLBACK_HTML_END_OF_LIST       = ' '
*       I_STRUCTURE_NAME        =
*       I_BACKGROUND_ID         = ' '
*       I_GRID_TITLE            =
*       I_GRID_SETTINGS         =
*       IS_LAYOUT               =
        IT_FIELDCAT             = IT_FIELDCAT
*       IT_EXCLUDING            =
*       IT_SPECIAL_GROUPS       =
*       IT_SORT                 =
*       IT_FILTER               =
*       IS_SEL_HIDE             =
*       I_DEFAULT               = 'X'
*       I_SAVE                  = ' '
*       IS_VARIANT              =
*       IT_EVENTS               =
*       IT_EVENT_EXIT           =
*       IS_PRINT                =
*       IS_REPREP_ID            =
*       I_SCREEN_START_COLUMN   = 0
*       I_SCREEN_START_LINE     = 0
*       I_SCREEN_END_COLUMN     = 0
*       I_SCREEN_END_LINE       = 0
*       I_HTML_HEIGHT_TOP       = 0
*       I_HTML_HEIGHT_END       = 0
*       IT_ALV_GRAPHICS         =
*       IT_HYPERLINK            =
*       IT_ADD_FIELDCAT         =
*       IT_EXCEPT_QINFO         =
*       IR_SALV_FULLSCREEN_ADAPTER        =
*       O_PREVIOUS_SRAL_HANDLER =
*       O_COMMON_HUB            =
*     IMPORTING
*       E_EXIT_CAUSED_BY_CALLER =
*       ES_EXIT_CAUSED_BY_USER  =
      TABLES
        T_OUTTAB                = IT_FINAL2
      EXCEPTIONS
        PROGRAM_ERROR           = 1
        OTHERS                  = 2.
    IF SY-SUBRC <> 0.
* Implement suitable error handling here
    ENDIF.


  ENDMETHOD.
ENDCLASS.

