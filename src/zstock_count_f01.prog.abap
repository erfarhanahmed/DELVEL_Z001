FORM USER_COMMAND USING R_UCOMM     LIKE SY-UCOMM
                        RS_SELFIELD TYPE SLIS_SELFIELD.

  REFRESH: IT_FINAL.
  READ TABLE IT_FINAL2 ASSIGNING FIELD-SYMBOL(<FS>) WITH KEY FISCAL_YEAR = RS_SELFIELD-VALUE.
  IF <FS> IS ASSIGNED.
    LV_YEAR = <FS>-FISCAL_YEAR.
    DATA(LV_LOW) = |{ RS_SELFIELD-VALUE }0401|.
    DATA(LV_HIGN) = |{ RS_SELFIELD-VALUE + 1 }0331|.


    LOOP AT IT_MATDOC INTO WA_MATDOC
        WHERE POSTINGDATE >= LV_LOW
          AND POSTINGDATE <= LV_HIGN.

*      READ TABLE IT_ZLOC_MAP ASSIGNING FIELD-SYMBOL(<FS_LOC>)
*        WITH KEY STRG_LOC = WA_MATDOC-STORAGELOCATION.
*      IF SY-SUBRC <> 0.
*        CONTINUE.
*      ENDIF.
*
*      LV_LOC   = <FS_LOC>-LOC_CODE.

      IF WA_MATDOC-MATERIAL IS NOT INITIAL.
        READ TABLE IT_MARA ASSIGNING FIELD-SYMBOL(<FS_MARA>)
          WITH KEY PRODUCT = WA_MATDOC-MATERIAL.
        IF SY-SUBRC <> 0.
          CONTINUE.
        ENDIF.
        LV_MATERIALGROUP = <FS_MARA>-PRODUCTGROUP.

        READ TABLE IT_T023_MARA ASSIGNING FIELD-SYMBOL(<FS_T023_MARA>)
          WITH KEY MATERIALGROUP = LV_MATERIALGROUP.
        IF SY-SUBRC <> 0.
          CONTINUE.
        ENDIF.
        LV_MATERIALGROUPNAME = <FS_T023_MARA>-MATERIALGROUPNAME.

      ELSE.
        READ TABLE IT_EKPO ASSIGNING FIELD-SYMBOL(<FS_EKPO>)
          WITH KEY PURCHASEORDER = WA_MATDOC-PURCHASEORDER
                   PURCHASEORDERITEM = WA_MATDOC-PURCHASEORDERITEM.
        IF SY-SUBRC <> 0.
          CONTINUE.
        ENDIF.
        LV_MATERIALGROUP = <FS_EKPO>-MATERIALGROUP.

        READ TABLE IT_T023_EKPO ASSIGNING FIELD-SYMBOL(<FS_T023_EKPO>)
          WITH KEY MATERIALGROUP = LV_MATERIALGROUP.
        IF SY-SUBRC <> 0.
          CONTINUE.
        ENDIF.
        LV_MATERIALGROUPNAME = <FS_T023_EKPO>-MATERIALGROUPNAME.

      ENDIF.

      READ TABLE IT_FINAL INTO WA_FINAL WITH KEY MATERIALGROUP = LV_MATERIALGROUP.        "PLANT = LV_LOC

      IF SY-SUBRC <> 0.
        CLEAR WA_FINAL.
        WA_FINAL-PLANT = P_WERKS.
        WA_FINAL-MATERIALGROUP  = LV_MATERIALGROUP.
        WA_FINAL-MATERIALGROUPNAME = LV_MATERIALGROUPNAME.
        APPEND WA_FINAL TO IT_FINAL.
        READ TABLE IT_FINAL INTO WA_FINAL INDEX SY-TABIX.
      ENDIF.

      LV_MON = WA_MATDOC-POSTINGDATE+4(2).

      CASE LV_MON.
        WHEN '01'.
          WA_FINAL-JAN_QTY = WA_FINAL-JAN_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-JAN_VAL = WA_FINAL-JAN_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '02'.
          WA_FINAL-FEB_QTY = WA_FINAL-FEB_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-FEB_VAL = WA_FINAL-FEB_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '03'.
          WA_FINAL-MAR_QTY = WA_FINAL-MAR_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-MAR_VAL = WA_FINAL-MAR_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '04'.
          WA_FINAL-APR_QTY = WA_FINAL-APR_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-APR_VAL = WA_FINAL-APR_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '05'.
          WA_FINAL-MAY_QTY = WA_FINAL-MAY_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-MAY_VAL = WA_FINAL-MAY_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '06'.
          WA_FINAL-JUN_QTY = WA_FINAL-JUN_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-JUN_VAL = WA_FINAL-JUN_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '07'.
          WA_FINAL-JUL_QTY = WA_FINAL-JUL_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-JUL_VAL = WA_FINAL-JUL_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '08'.
          WA_FINAL-AUG_QTY = WA_FINAL-AUG_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-AUG_VAL = WA_FINAL-AUG_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '09'.
          WA_FINAL-SEP_QTY = WA_FINAL-SEP_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-SEP_VAL = WA_FINAL-SEP_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '10'.
          WA_FINAL-OCT_QTY = WA_FINAL-OCT_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-OCT_VAL = WA_FINAL-OCT_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '11'.
          WA_FINAL-NOV_QTY = WA_FINAL-NOV_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-NOV_VAL = WA_FINAL-NOV_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
        WHEN '12'.
          WA_FINAL-DEC_QTY = WA_FINAL-DEC_QTY + WA_MATDOC-QUANTITYINBASEUNIT.
          WA_FINAL-DEC_VAL = WA_FINAL-DEC_VAL + WA_MATDOC-TOTALGOODSMVTAMTINCCCRCY.
      ENDCASE.

      MODIFY IT_FINAL FROM WA_FINAL INDEX SY-TABIX.

    ENDLOOP.

    SORT IT_FINAL ASCENDING BY MATERIALGROUP.

  ENDIF.

  PERFORM GET_FCAT2.
  PERFORM DISPLAY_DATA2.

ENDFORM.

