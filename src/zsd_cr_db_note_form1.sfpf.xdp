            <draw h="7.112mm" name="Text3" w="202.132mm">
               <ui>
                  <textEdit/>
               </ui>
               <value>
                  <text xliff:rid="847CE21C-A883-476D-80A2-5977DBFFBF4F">TERMS AND CONDITIONS : 1) Our responsibility ceases on delivery of goods to Transporter / as per individual P.O. 2)No Claim will be entertained if not lodged within two weeks from the date of our invoice . 3) All transactions and bills are subject to Pune Jurisdication. 4) Interest @ 24% will be charged extra if not paid within agreed period.</text>
               </value>
               <font baselineShift="0pt" size="6pt" typeface="Times New Roman"/>
               <margin bottomInset="1mm" leftInset="1mm" rightInset="1mm" topInset="1mm"/>
               <para marginLeft="2.16pt" marginRight="0pt" spaceAbove="0pt" spaceBelow="0pt" textIndent="0pt" vAlign="middle"/>
               <border>
                  <edge/>
                  <corner/>
