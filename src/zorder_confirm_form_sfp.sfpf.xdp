<?xml version="1.0"?><?xfa generator="SAP_SmartForms" APIVersion="R700.SP0.N0"?><xdp:xdp xmlns:xdp="http://ns.adobe.com/xdp/"><template xmlns="http://www.xfa.org/schema/xfa-template/2.2/"><subform name="ZORDER_CONFIRM"><event ref="$form" activity="ready"><script contentType="application/x-javascript" binding="XFA"><![CDATA[

// Outstanding Javascript issues:
//
// - Subform conditions in body page subforms that use $layout generate errors when used interactively.
// - Implement the moving of a subform's variables (waiting on XFALang proposal).
// - Adjust the XML wrapper string when appending plain text to rich text in CopyDrawText().
//   It currently has ISO 8859-1 hardcoded which probably isn't right.  I need to find out what
//   encoding Javascript strings are in
// - The JS code doesn't currently handle international characters very well.  Any characters that
//   are outside ISO-8859-1 when running on a US-English system are lost.
//   This is currently awaiting bug #638382
// - Can't handle conditions that reference $layout in Main windows.  SAP may be able to live with this.


//
// This function looks for a field in the list of direct children of the
// passed in node for a child node with the specified name and and returns it.
//
// return: the field

function FindSubformField(XFANode, nodeName) {

	if (XFANode == null || nodeName == null) {

		xfa.log.message(1, "FindSubformField: One of the arguments was null, cannot find node.");
		return null;
	}

	var children = XFANode.nodes;

//xfa.log.message(1,"FindSubformField: Looking for node name: " + nodeName);
	for (var i=0; i < children.length; i++) {

		var curNode = children.item(i);
//xfa.log.message(1,"FindSubformField: child=" + i + " curNode=" + curNode.className + " name=" + curNode.name);
		if (curNode.className == "field" && curNode.name == nodeName) {

		    return curNode;
		}
    }

	return null;
}



//
// This function searches a container and any children that it may contain
// (and potentialy the children's children).
//
// It receives a paramater object that contains two methods and a property:
//	Parms.Target - Property that contains the className of nodes to test
//	Parms.Condition - Method that returns true or false.  If true for any nodes
//                        of type Parms.Target, then this function performs Parms.Action
//	Parms.Action - Method to be performed on nodes when Parms.condition is true

function WalkTreeFromHere( curNode, MyParms ) {

	//
	// If the current node is one of the ones that supports children... (i.e.
	// is a container), figure out if we should do something special with it.

//xfa.log.message(1, "WalkTreeFromHere: got here 1");
	if (curNode.className == "subform" || curNode.className == "area" ||
	    curNode.className == "pageSet" || curNode.className == "pageArea" ||
	    curNode.className == "subformSet") {

//xfa.log.message(1,"WalkTreeFromHere: Examining "+curNode.className+" "+curNode.name);
		//
		// Look for a node of type target and then if the condition is true, then perform the action.

		var bNeedToLookAtChildren = true;

		if (curNode.className == MyParms.Target) {

			var controllerNode = FindSubformField(curNode, MyParms.ConditionController);

			if (controllerNode != null) {

				//
				// If we got back a condition node (such as as a field named
				// subform_condition__ or append_mode__, perform an action
				// on the current node based ont he contents of the controller
				// field.

				bNeedToLookAtChildren = false;
//xfa.log.message(1, "WalkTreeFromHere: got here 2");
				MyParms.Action(curNode, controllerNode.rawValue);
//xfa.log.message(1, "WalkTreeFromHere: got here 3");
			}
		}

		if (bNeedToLookAtChildren == true) {

//xfa.log.message(1,"WalkTreeFromHere: Examining it's children");
			var children = curNode.nodes;
			for (var i=0; i < children.length; i++) {

//xfa.log.message(1,"WalkTreeFromHere: child="+i+" curNode="+children.item(i).className);
				WalkTreeFromHere(children.item(i), MyParms);
			}		
		}
//xfa.log.message(1, "WalkTreeFromHere: got here 4");

	} else {

//xfa.log.message(1,"WalkTreeFromHere: Skipping " + curNode.className);
	}
//xfa.log.message(1, "WalkTreeFromHere: got here 5");
}



//
// This function removes a subform

function RemoveSubform(XFANode, controlValue) {

//xfa.log.message(1, "RemoveSubform: should we remove "+XFANode.name+"....control value: " + controlValue );
	if (controlValue != null && Boolean(Number(controlValue))) {

//xfa.log.message(1, "RemoveSubform: Removing-"+XFANode.name+"." );
 		XFANode.instanceManager.removeInstance(0);
	}
}



//
// This function handles all the subform conditions within the FormDOM.
// It will remove all subforms whose conditions are false.

function HandleFormDOMConditions() {

	var Parms = new Object;
	Parms.ConditionController = "subform_condition__";
	Parms.Action = RemoveSubform;
	Parms.Target = "subform";
	WalkTreeFromHere(xfa.resolveNode("$form.#subform[0]"), Parms );
}



//
// This function finds the previous subform within the same parent.
//
function FindPreviousSubform( XFANode )
{
	//xfa.log.message(1, "Finding subform previous to "+XFANode.name+"." );
	var Siblings = XFANode.parent.nodes;
	var PrevSubform = null;
	var PrevSibling = null;
	for (var i = 0; i < Siblings.length && (PrevSibling = Siblings.item(i)) != XFANode; i++ )
	{
		if ( PrevSibling.className == "subform" )
			PrevSubform = PrevSibling;
	}
	if ( i >= Siblings.length )
	{
		// This shouldn't happen
		xfa.log.message(1, "Oops!  Ran out of siblings.  Node="+XFANode.name+", parent="+XFANode.parent.name+", # of children="+Siblings.length+", i="+i+"." );
	}
	else if (PrevSubform == null )
	{
		// This shouldn't happen either
		xfa.log.message(1, "Oops!  No Previous Subform.  Node="+XFANode.name+"." );
	}
//	else
//		xfa.log.message(1, "Found Previous Subform.  Node="+XFANode.name+", Sibling="+PrevSubform.name+"." );
	
	return( PrevSubform );
}




//
// This function returns 1 if TheDraw is a plain text draw, 2 if it is a rich
// text draw, and 0 if unknown.

function GetTextType(TheDraw) {

//xfa.log.message(1, "GetTextType: find text type for " + TheDraw.name + " " + TheDraw.className + ".");
	var retVal = 0;
	var CurChild = TheDraw.value.oneOfChild;

//xfa.log.message(1, "Checking Value Node="+CurChild.className+"." );
	if (CurChild.className == "text" || (CurChild.className == "exData" && CurChild.contentType == "text/plain")) {

		retVal = 1;

	} else if (CurChild.className == "exData" && (CurChild.contentType == "text/xhtml" || CurChild.contentType == "text/html" )) {

		retVal = 2;
	}

	return retVal;
}



//
// This function determines whether a <draw> is textual.

function GetTextFromDraw( TheDraw ) {

//xfa.log.message(1, "GetTextFromDraw: find text for " + TheDraw.name + " " + TheDraw.className + ".");
	// If we find a child of value that is of type text, then
	// we return it.
	var textType = GetTextType(TheDraw);

	if (textType == 1) {

//xfa.log.message(1, "Found text." );
		return TheDraw.value.oneOfChild;

	} else if (textType == 2) {

//xfa.log.message(1, "GetTextFromDraw: found rich text node " + TheDraw.name + ".");
		return TheDraw.value.oneOfChild;

	} else {

		// I guess we didn't find any text children.
		return null;
	}
}




//
// This function finds the last textual <draw> within a subform.

function FindLastTextDraw( TheSubform ) {

//xfa.log.message(1, "FindLastTextDraw: find last text for " + TheSubform.name + " " + TheSubform.className + ".");
	// check that this is actually a subform
	if ( TheSubform.className != "subform" ) {

		xfa.log.message(1, "FindLastTextDraw: Oops!  Tried to find last draw within a non-subform.  Node="+TheSubform.name+"." );
		return( null );
	}

	var Children = TheSubform.nodes;
	var LastDraw = null;
	var CurChild = null;
	for (var i = 0; i < Children.length; i++ ) {

		CurChild = Children.item(i);

//xfa.log.message(1, "FindLastTextDraw: searching child " + CurChild.name + " " + CurChild.className + ".");
		if ((CurChild.className == "draw" || CurChild.className == "field") && GetTextFromDraw(CurChild)!= null) {
		//if (CurChild.className == "draw" && GetTextFromDraw(CurChild)!= null) {
			
			LastDraw = CurChild;
		}
	}
	
	if (LastDraw == null )
		xfa.log.message(1, "FindLastTextDraw: No <draws> or <fields> within subform.  Node="+TheSubform.name+"." );

//	else
		//xfa.log.message(1, "Found <draw>.  Node="+LastDraw.name+"." );

	return( LastDraw );
}




//
// This function strips all the XML tags out of a string of XML.
//
function StripXMLTags( SourceString )
{
//xfa.log.message(1, "Stripping XML from="+SourceString+"." );
	var ResultString = "";
	var InsideTag = false; // variable to indicate that we a currently inside an XML tag
	var WhitespaceRun = false; // variable to indicate we're currently inside a run of whitespace

	for( var i = 0; i < SourceString.length; i++ )
	{
		if ( SourceString.charAt(i) == "<" )
		{
			InsideTag = true;
		}
		else if ( SourceString.charAt(i) == ">" )
		{
			InsideTag = false;
		}
		else if ( InsideTag == false )
		{
			// Condense whitespace
			if (    SourceString.charAt(i) == " "
			     || SourceString.charAt(i) == "\t"
			     || SourceString.charAt(i) == "\n"
			   )
			{
				if (WhitespaceRun == false)
				{
					WhitespaceRun = true;
					ResultString = ResultString + " ";
				}
				// If WhitespaceRun == true, then we do nothing
			}
			else
			{
				// Copy the character if we're not inside a tag
				ResultString = ResultString + SourceString.charAt(i);
				WhitespaceRun = false;
			}
		}
	}
	
	return( ResultString );
}




//
// This function appends a newline to a text draw.

function AppendNewline(TargetDraw) {

	var textType = GetTextType(TargetDraw);

	if (textType == 1) {

//xfa.log.message(1, "AppendNewline: " + TargetDraw.name + " is plain text." );
		GetTextFromDraw(TargetDraw).value = GetTextFromDraw(TargetDraw).value + "\n";

	} else if (textType == 2) {

//xfa.log.message(1, "AppendNewline: " + TargetDraw.name + " is rich text." );
		GetTextFromDraw(TargetDraw).oneOfChild.loadXML("<br />", false);
//xfa.log.message(1, "AppendNewline: Resulting XML after appending newline:\n"+GetTextFromDraw(TargetDraw).oneOfChild.saveXML()+"\nEnd of Resulting XML." );

	} else {

		xfa.log.message(1, "Problem appending newline draw="+TargetDraw.name+" -- Unknown text type.");
	}
}




//
// This function copies the text from one draw into another.

function CopyDrawText(SourceDraw, TargetDraw) {

	var sourceDrawType = GetTextType(SourceDraw);
	var targetDrawType = GetTextType(TargetDraw);

	if (sourceDrawType == 1 && targetDrawType == 1) {   // both are plain text

//xfa.log.message(1, "CopyDrawText:  From=" + SourceDraw.name + " (plain text: " + GetTextFromDraw(SourceDraw).value + "), To=" + TargetDraw.name + " (plain text: " + GetTextFromDraw(TargetDraw).value + "." );
		GetTextFromDraw(TargetDraw).value = GetTextFromDraw(TargetDraw).value + GetTextFromDraw(SourceDraw).value
//xfa.log.message(1, "CopyDrawText: Resulting Text: " + GetTextFromDraw(TargetDraw).value + ".");

	} else if (sourceDrawType == 2 && targetDrawType == 2) {    // both are rich text

//xfa.log.message(1, "CopyDrawText:  From=" + SourceDraw.name + " (rich text:\n\n" + GetTextFromDraw(SourceDraw).oneOfChild.saveXML() + "\n\n), To=" + TargetDraw.name + " (rich text:\n\n" + GetTextFromDraw(TargetDraw).oneOfChild.saveXML() + "\n\n." );
		GetTextFromDraw(TargetDraw).oneOfChild.loadXML( GetTextFromDraw(SourceDraw).oneOfChild.saveXML(), true );
//xfa.log.message(1, "CopyDrawText: Resulting XML from\n"+GetTextFromDraw(TargetDraw).oneOfChild.saveXML()+"\nEnd of Resulting XML." );

	} else if (sourceDrawType == 1 && targetDrawType == 2) {      // source is plain and target is rich

//xfa.log.message(1, "CopyDrawText:  From=" + SourceDraw.name + " (plain text: " + GetTextFromDraw(SourceDraw).value + "), To=" + TargetDraw.name + " (rich text: " + GetTextFromDraw(TargetDraw).oneOfChild.saveXML() + "." );
		//GetTextFromDraw(TargetDraw).oneOfChild.loadXML( "<?xml version=\"1.0\" encoding=\"ISO-8859-1\"?><body xmlns=\"http://www.w3.org/1999/xhtml\" xmlns:xfa=\"http://www.xfa.org/schema/xfa-data/1.0/\" xfa:APIVersion=\"1.4.3208.0\"><p>" +
		GetTextFromDraw(TargetDraw).oneOfChild.loadXML( "<?xml version=\"1.0\" encoding=\"ISO-8859-1\"?><body xmlns=\"http://www.w3.org/1999/xhtml\" xmlns:xfa=\"http://www.xfa.org/schema/xfa-data/1.0/\" xfa:APIVersion=\"1.4.3208.0\"><p>" +
GetTextFromDraw(SourceDraw).value + "</p></body>", true );
//xfa.log.message(1, "CopyDrawText: Resulting XML from\n"+GetTextFromDraw(TargetDraw).oneOfChild.saveXML()+"\nEnd of Resulting XML." );

	} else if (sourceDrawType == 2 && targetDrawType == 1) {    // source is rich and target is plain

//xfa.log.message(1, "CopyDrawText:  From=" + SourceDraw.name + " (rich text: " + GetTextFromDraw(SourceDraw).oneOfChild.saveXML() + "), To=" + TargetDraw.name + " (plain text: " + GetTextFromDraw(TargetDraw).value + "." );
		GetTextFromDraw(TargetDraw).value = GetTextFromDraw(TargetDraw).value + StripXMLTags(GetTextFromDraw(SourceDraw).oneOfChild.saveXML());
//xfa.log.message(1, "CopyDrawText: Resulting Text: " + GetTextFromDraw(TargetDraw).value + ".");

	} else {

		xfa.log.message(1, "Problem copying Draw text.  Unknown text types encountered.  From="+SourceDraw.name+", To="+TargetDraw.name+"." );
	}
}




//
// This function copies all the variables from one Subform into another.
//
function CopySubformVariables( SourceSubform, TargetSubform )
{
	// RTM - This will need to be updated once the syntax for variables is determined.
//xfa.log.message(1, "Copying Subform Variables.  From="+SourceSubform.name+", To="+TargetSubform.name+"." );
}




//
// This function appends a subform to the previous subform within the same parent.

function AppendSubformToPrevious( CurSubform ) {

//xfa.log.message(1, "AppendSubformToPrevious: Appending-"+CurSubform.name+"." );

	var PrevSubform = FindPreviousSubform(CurSubform);

	if (PrevSubform != null) {

		var PrevSubTextDraw = FindLastTextDraw(PrevSubform);
		var CurSubTextDraw = FindLastTextDraw(CurSubform);

		if (PrevSubTextDraw != null) {

			CopyDrawText(CurSubTextDraw, PrevSubTextDraw);
		}

		CopySubformVariables(CurSubform, PrevSubform);
		RemoveSubform(CurSubform, "1");
	}
}




//
// This function appends a subform to the previous subform within the same parent
// with a newline seperator.

function AppendSubformToPreviousWithNewline(CurSubform) {

//xfa.log.message(1, "AppendSubformToPreviousWithNewline: AppendingWithNewline-"+CurSubform.name+"." );

	var PrevSubform = FindPreviousSubform(CurSubform);

	if (PrevSubform != null) {

//xfa.log.message(1, "AppendSubformToPreviousWithNewline: Found previous subform-"+PrevSubform.name+"." );
		var PrevSubTextDraw = FindLastTextDraw(PrevSubform);
		var CurSubTextDraw = FindLastTextDraw(CurSubform);

		if (PrevSubTextDraw != null) {

//xfa.log.message(1, "AppendSubformToPreviousWithNewline: Found previous subform text-"+PrevSubTextDraw.name+"." );
			AppendNewline(PrevSubTextDraw);
			CopyDrawText(CurSubTextDraw, PrevSubTextDraw);
		}

		CopySubformVariables(CurSubform, PrevSubform);
		RemoveSubform(CurSubform, "1");
	}
}



//
// This function action's a subform's append mode

function PerformSubformAppendMode(XFANode, AppendMode) {

	if (AppendMode != null) {

//xfa.log.message(1, "PerformSubformAppendMode: Actioning " + XFANode.name + "'s append mode (" + AppendMode + ")");
		if (AppendMode == "P") {

			; // Do Nothing

		} else if (AppendMode == "A") {

			AppendSubformToPrevious(XFANode);

		} else if (AppendMode == "N") {

			AppendSubformToPreviousWithNewline(XFANode);

		} else {

			xfa.log.message(1, "Unknown append mode (" + AppendMode + ") on subform " + XFANode.name);
		}
	}
}



//
// This function handles appending any subforms within the FormDOM
// based on the append_mode__ field.

function HandleFormDOMAppendModes() {

	var Parms = new Object;
	Parms.ConditionController = "append_mode__";
	Parms.Action = PerformSubformAppendMode;
	Parms.Target = "subform";
//xfa.log.message(1, "HandleFormDOMAppendMode: got here 1");
	WalkTreeFromHere(xfa.resolveNode("$form.#subform[0]"), Parms );
//xfa.log.message(1, "HandleFormDOMAppendMode: got here 2");
}



//
// This function handles all the subform conditions within the Layout structure.
// It will remove all subforms whose conditions are false.
//
function HandleLayoutStructureConditions()
{
	var Parms = new Object;
	Parms.ConditionController = "subform_condition__";
	Parms.Action = RemoveSubform;
	Parms.Target = "subform";

	var nPages = xfa.layout.pageCount();
	for (var i = 0; i < nPages; i++) {

//xfa.log.message(1, "HandleLayoutStructureConditions: Examining Page " + i);
		var nodes = xfa.layout.pageContent(i);

		for (var j = 0; j < nodes.length; j++) {

			var node = nodes.item(j);
			WalkTreeFromHere(node, Parms);
		}

		xfa.layout.relayoutPageArea(i);
	}
}

// Start at the top subform and search it's children
//xfa.log.message(1, "form:ready: got here 1");
HandleFormDOMConditions();
//xfa.log.message(1, "form:ready: got here 2");
//xfa.log.message(1, "","i" );
//xfa.log.message(1, "","i" );
//xfa.log.message(1, "","i" );
//xfa.log.message(1, "form:ready: got here 3");
HandleFormDOMAppendModes();
//xfa.log.message(1, "form:ready: got here 4");
]]></script></event><event ref="$layout" activity="ready"><script contentType="application/x-javascript" binding="XFA"><![CDATA[//xfa.log.message(1, "","i" );
