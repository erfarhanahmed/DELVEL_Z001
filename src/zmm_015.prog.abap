      E_MONTH = E_MONTH.

*      SELECT ebeln, ebelp, eindt, menge , wemng
*      FROM EKET
*      INTO TABLE @DATA(gt_eket)
*         WHERE EBELN IN  ( SELECT EBELN FROM EKKO WHERE bstyp = 'F' AND loekz = '' )
*        AND eindt BETWEEN @gv_sdate AND @gv_edate.

*  SELECT purchasingdocument AS ebeln, purchasingdocumentitem AS ebelp, schedulelinedeliverydate AS eindt, schedulelineorderquantity AS menge , roughgoodsreceiptqty AS wemng
*  FROM vfclmmmeket
*  INTO TABLE @DATA(gt_eket)
*     WHERE purchasingdocument IN  ( SELECT purchasingdocument FROM vfclmmmekko WHERE purchasingdocumentcategory = 'F' AND purchasingdocumentdeletioncode = '' )
*    AND schedulelinedeliverydate BETWEEN @gv_sdate AND @gv_edate.
*  gv_sdate = '20250501'.
*  gv_edate = '20250531'.
  SELECT A~PURCHASINGDOCUMENT AS EBELN,
  A~PURCHASINGDOCUMENTITEM AS EBELP,
  A~SCHEDULELINEDELIVERYDATE AS EINDT,
  A~SCHEDULELINEORDERQUANTITY AS MENGE,
  A~ROUGHGOODSRECEIPTQTY AS WEMNG
  FROM VFCLMMMEKET AS A
  INNER JOIN VFCLMMMEKKO AS B
  ON A~PURCHASINGDOCUMENT = B~PURCHASINGDOCUMENT
  WHERE B~PURCHASINGDOCUMENTCATEGORY = 'F'
  AND B~PURCHASINGDOCUMENTDELETIONCODE = ''
  AND A~SCHEDULELINEDELIVERYDATE GE @GV_SDATE
  AND A~SCHEDULELINEDELIVERYDATE LE @GV_EDATE
*  AND a~schedulelinedeliverydate BETWEEN @gv_sdate AND @gv_edate
  INTO TABLE @DATA(GT_EKET).




  IF GT_EKET IS NOT INITIAL.
    SELECT   PURCHASINGDOCUMENT AS EBELN,
             PURCHASINGDOCUMENTITEM AS EBELP,
             MATERIAL AS MATNR,
             NETPRICEAMOUNT AS NETPR,
*             NETPRICEQUANTITY AS peinh,
             ISCOMPLETELYDELIVERED AS ELIKZ,
             PURCHASINGDOCUMENTDELETIONCODE AS LOEKZ
    INTO TABLE @DATA(GT_EKKO)
          FROM VFCLMMMEKPO
      FOR ALL ENTRIES IN @GT_EKET
      WHERE PURCHASINGDOCUMENT = @GT_EKET-EBELN
          AND PLANT = @P_WERKS
          AND PURCHASINGDOCUMENTDELETIONCODE <> 'L'
          AND ISCOMPLETELYDELIVERED = ''.
  ENDIF.
  DELETE  GT_EKKO WHERE ELIKZ = 'X'.
  DELETE  GT_EKKO WHERE LOEKZ = 'L'.

  DATA: GT_EKKO_T LIKE  GT_EKKO.
  GT_EKKO_T[] = GT_EKKO[].

  SORT GT_EKKO_T BY MATNR.
  SORT GT_EKKO BY MATNR.
  DELETE ADJACENT DUPLICATES FROM GT_EKKO_T COMPARING MATNR.

  IF GT_EKKO_T IS NOT INITIAL.
    SELECT MATNR , MTART, ZITEM_CLASS
    FROM MARA
    INTO TABLE @DATA(GT_MARA)
          FOR ALL ENTRIES IN  @GT_EKKO_T
          WHERE MATNR = @GT_EKKO_T-MATNR.
*      AND mtart = 'HALB' AND zitem_class = 'A'.

  ENDIF.

  DATA(LV_COUNT) = REDUCE I(
        INIT X = 0
        FOR WA IN GT_MARA WHERE ( ZITEM_CLASS = '' )
        NEXT X = X + 1 ).

  MESSAGE |{ LV_COUNT } Materials does not have Item Class for above selection| TYPE 'S'.

  DELETE GT_MARA WHERE ZITEM_CLASS = ''.

  LOOP AT GT_EKET INTO DATA(EKET) .
    IF EKET-MENGE NE EKET-WEMNG .
      READ TABLE GT_EKKO INTO DATA(GS_EKKO) WITH KEY EBELN = EKET-EBELN
                                                       EBELP = EKET-EBELP.
      IF SY-SUBRC IS INITIAL.

        READ TABLE GT_MARA INTO DATA(GS_MARA) WITH KEY MATNR = GS_EKKO-MATNR.
        IF SY-SUBRC IS INITIAL.
          GS_EKET1-MENGE =  ( EKET-MENGE - EKET-WEMNG ).
          GS_EKET1-NETPR =  ( GS_EKET1-MENGE * GS_EKKO-NETPR ) / 100000.
          GS_EKET1-MTART =   GS_MARA-MTART.
          GS_EKET1-CLASS =   GS_MARA-ZITEM_CLASS.
        ENDIF.
      ELSE.
        CLEAR : GS_EKET1, EKET , GS_MARA, GS_MARA.
        CONTINUE.
      ENDIF.
    ENDIF.

    PERFORM GET_CURRENT_MONTH_ITEM USING EKET-EINDT.
    GS_EKET1-DMONTH = GV_CMONTH.
    COLLECT GS_EKET1 INTO GT_EKET1.
    CLEAR : GS_EKET1, EKET , GS_MARA, GS_MARA.

  ENDLOOP.

  REFRESH GT_RESULT.
  CLEAR GS_RESULT.
  SORT GT_EKET1 BY MTART CLASS DMONTH.

  DELETE GT_EKET1 WHERE MENGE IS INITIAL.

  LOOP AT GT_EKET1 INTO GS_EKET1 .
    GS_RESULT-CLASS =  GS_EKET1-CLASS.
    GS_RESULT-MTART =  GS_EKET1-MTART.
    CASE GS_EKET1-DMONTH+0(3).
      WHEN 'JAN'.
        GS_FLAG-V_JAN = 'X'.
        GS_RESULT-V_JAN =  GS_RESULT-V_JAN + GS_EKET1-NETPR .
        GS_RESULT-Q_JAN =  GS_RESULT-V_JAN + GS_EKET1-MENGE .
      WHEN 'FEB'.
        GS_FLAG-V_FEB = 'X'.
        GS_RESULT-V_FEB =  GS_RESULT-V_FEB + GS_EKET1-NETPR .
        GS_RESULT-Q_FEB =  GS_RESULT-V_FEB + GS_EKET1-MENGE .
      WHEN 'MAR'.
        GS_FLAG-V_MAR = 'X'.
        GS_RESULT-V_MAR =  GS_RESULT-V_MAR + GS_EKET1-NETPR .
        GS_RESULT-Q_MAR =  GS_RESULT-V_MAR + GS_EKET1-MENGE .
      WHEN 'APR'.
        GS_FLAG-V_APR = 'X'.
        GS_RESULT-V_APR =  GS_RESULT-V_APR + GS_EKET1-NETPR .
        GS_RESULT-Q_APR =  GS_RESULT-V_APR + GS_EKET1-MENGE .
      WHEN 'MAY'.
        GS_FLAG-V_MAY = 'X'.
        GS_RESULT-V_MAY =  GS_RESULT-V_MAY + GS_EKET1-NETPR .
        GS_RESULT-Q_MAY =  GS_RESULT-V_MAY + GS_EKET1-MENGE .
      WHEN 'JUN'.
        GS_FLAG-V_JUN = 'X'.
        GS_RESULT-V_JUN =  GS_RESULT-V_JUN + GS_EKET1-NETPR .
        GS_RESULT-Q_JUN =  GS_RESULT-V_JUN + GS_EKET1-MENGE .
      WHEN 'JUL'.
        GS_FLAG-V_JUL = 'X'.
        GS_RESULT-V_JUL =  GS_RESULT-V_JUL + GS_EKET1-NETPR .
        GS_RESULT-Q_JUL =  GS_RESULT-V_JUL + GS_EKET1-MENGE .
      WHEN 'AUG'.
        GS_FLAG-V_AUG = 'X'.
        GS_RESULT-V_AUG =  GS_RESULT-V_AUG + GS_EKET1-NETPR .
        GS_RESULT-Q_AUG =  GS_RESULT-V_AUG + GS_EKET1-MENGE .
      WHEN 'SEP'.
        GS_FLAG-V_SEP = 'X'.
        GS_RESULT-V_SEP =  GS_RESULT-V_SEP + GS_EKET1-NETPR .
        GS_RESULT-Q_SEP =  GS_RESULT-V_SEP + GS_EKET1-MENGE .
      WHEN 'OCT'.
        GS_FLAG-V_OCT = 'X'.
        GS_RESULT-V_OCT =  GS_RESULT-V_OCT + GS_EKET1-NETPR .
        GS_RESULT-Q_OCT =  GS_RESULT-V_OCT + GS_EKET1-MENGE .
      WHEN 'NOV'.
        GS_FLAG-V_NOV = 'X'.
        GS_RESULT-V_NOV =  GS_RESULT-V_NOV + GS_EKET1-NETPR .
        GS_RESULT-Q_NOV =  GS_RESULT-V_NOV + GS_EKET1-MENGE .
      WHEN 'DEC'.
        GS_FLAG-V_DEC = 'X'.
        GS_RESULT-V_DEC =  GS_RESULT-V_DEC +  GS_EKET1-NETPR .
        GS_RESULT-Q_DEC =  GS_RESULT-V_DEC +  GS_EKET1-MENGE .
      WHEN OTHERS.
    ENDCASE.

    AT END OF CLASS.
      LV_END = 'X'.
    ENDAT.
    AT END OF MTART.
      LV_END = 'X'.
    ENDAT.

    IF LV_END = 'X'.
      APPEND GS_RESULT TO GT_RESULT.
      CLEAR :GS_RESULT, LV_END.
    ENDIF.
  ENDLOOP.


ENDFORM.

