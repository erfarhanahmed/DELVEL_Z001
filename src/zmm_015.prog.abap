FORM V_DATA.

*  SELECT EBELN,
*         BSTYP
*    FROM EKKO
*    INTO TABLE @DATA(IT_1)
*    WHERE BSTYP EQ 'F'.
*
*  SELECT EBELN,
*         EBELP,
*         MATNR,
*         LOEKZ,
*         NETPR
*    FROM EKPO
*    INTO TABLE @DATA(IT_2)
*    FOR ALL ENTRIES IN @IT_1
*    WHERE EBELN EQ @IT_1-EBELN
*    AND MATNR <> @SPACE
*    AND WERKS = @P_WERKS
*    AND LOEKZ <> 'L'.

  S_EINDT-SIGN = 'I'.
  S_EINDT-OPTION = 'BT'.
  S_EINDT-LOW = |{ P_YEAR }0401|.
  S_EINDT-HIGH = |{ P_YEAR + 1 }0401|.
  APPEND S_EINDT TO S_EINDT[].


  SELECT A~EBELN,
         A~BSTYP,
         B~EBELP,
         B~MATNR,
         B~LOEKZ,
         B~NETPR,
         B~ELIKZ,
         C~MENGE,
         C~WEMNG,
         C~EINDT
    FROM EKKO AS A
    INNER JOIN EKPO AS B ON B~EBELN = A~EBELN
    INNER JOIN EKET AS C ON C~EBELN = B~EBELN AND C~EBELP = B~EBELP
    WHERE A~BSTYP = 'F'
    AND A~BSART NE 'ZRP'
    AND EINDT IN @S_EINDT
    AND B~MATNR <> @SPACE
    AND B~WERKS = @P_WERKS
    AND B~LOEKZ <> 'L'
    INTO TABLE @DATA(IT_EKKO).

  IF IT_EKKO IS NOT INITIAL.

    SELECT MATNR,
       MTART,
       ZITEM_CLASS
      FROM MARA
      INTO TABLE @DATA(IT_MARA)
      FOR ALL ENTRIES IN @IT_EKKO
      WHERE MATNR = @IT_EKKO-MATNR
      AND ZITEM_CLASS IN ( 'A' , 'B' , 'C' , ' ' ).

  ENDIF.



  LOOP AT IT_EKKO INTO DATA(WA_EKKO).

    IF  WA_EKKO-MENGE NE WA_EKKO-WEMNG.

      LV_QTY_DIFF = WA_EKKO-MENGE - WA_EKKO-WEMNG.
      IF WA_EKKO-ELIKZ EQ 'X'.
        CONTINUE.
      ENDIF.

      READ TABLE IT_MARA ASSIGNING FIELD-SYMBOL(<FS_MARA>) WITH KEY MATNR = WA_EKKO-MATNR.
      IF SY-SUBRC NE 0.
        CONTINUE.
      ENDIF.

      LV_MTART = <FS_MARA>-MTART.
      LV_ZITEM_CLASS = <FS_MARA>-ZITEM_CLASS.

      READ TABLE IT_FINAL INTO WA_FINAL WITH KEY MTART = <FS_MARA>-MTART ZITEM_CLASS = <FS_MARA>-ZITEM_CLASS.

      IF SY-SUBRC <> 0.

        WA_FINAL-MTART = LV_MTART.
        WA_FINAL-ZITEM_CLASS = LV_ZITEM_CLASS.
        APPEND WA_FINAL TO IT_FINAL.
        READ TABLE IT_FINAL INTO WA_FINAL INDEX SY-TABIX.

      ENDIF.

      LV_MON = WA_EKKO-EINDT+4(2).

      CASE LV_MON.
        WHEN '01'.
          WA_FINAL-JAN_QTY = WA_FINAL-JAN_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-JAN_VAL = WA_FINAL-JAN_VAL + LV_VAL.
        WHEN '02'.
          WA_FINAL-FEB_QTY = WA_FINAL-FEB_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-FEB_VAL = WA_FINAL-FEB_VAL + LV_VAL.
        WHEN '03'.
          WA_FINAL-MAR_QTY = WA_FINAL-MAR_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-MAR_VAL = WA_FINAL-MAR_VAL + LV_VAL.
        WHEN '04'.
          WA_FINAL-APR_QTY = WA_FINAL-APR_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-APR_VAL = WA_FINAL-APR_VAL + LV_VAL.
        WHEN '05'.
          WA_FINAL-MAY_QTY = WA_FINAL-MAY_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-MAY_VAL = WA_FINAL-MAY_VAL + LV_VAL.
        WHEN '06'.
          WA_FINAL-JUN_QTY = WA_FINAL-JUN_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-JUN_VAL = WA_FINAL-JUN_VAL + LV_VAL.
        WHEN '07'.
          WA_FINAL-JUL_QTY = WA_FINAL-JUL_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-JUL_VAL = WA_FINAL-JUL_VAL + LV_VAL.
        WHEN '08'.
          WA_FINAL-AUG_QTY = WA_FINAL-AUG_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-AUG_VAL = WA_FINAL-AUG_VAL + LV_VAL.
        WHEN '09'.
          WA_FINAL-SEP_QTY = WA_FINAL-SEP_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-SEP_VAL = WA_FINAL-SEP_VAL + LV_VAL.
        WHEN '10'.
          WA_FINAL-OCT_QTY = WA_FINAL-OCT_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-OCT_VAL = WA_FINAL-OCT_VAL + LV_VAL.
        WHEN '11'.
          WA_FINAL-NOV_QTY = WA_FINAL-NOV_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-NOV_VAL = WA_FINAL-NOV_VAL + LV_VAL.
        WHEN '12'.
          WA_FINAL-DEC_QTY = WA_FINAL-DEC_QTY + LV_QTY_DIFF.
          LV_VAL = ( LV_QTY_DIFF * WA_EKKO-NETPR ) / 100000.
          WA_FINAL-DEC_VAL = WA_FINAL-DEC_VAL + LV_VAL.
      ENDCASE.

    ENDIF.

    MODIFY IT_FINAL FROM WA_FINAL INDEX SY-TABIX.
    CLEAR: LV_VAL, LV_QTY_DIFF.

  ENDLOOP.

  CLEAR: WA_FINAL.
  SORT IT_FINAL BY MTART ZITEM_CLASS.
*  IT_FINAL1 = IT_FINAL.

  WA_FIELDCAT-FIELDNAME = 'MTART'.
