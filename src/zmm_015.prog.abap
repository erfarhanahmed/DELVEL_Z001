*&---------------------------------------------------------------------*
*& Form FILL_FCAT
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> FIELD
*&      --> LENGTH
*&      --> DESC_M
*&      --> EDIT
*&---------------------------------------------------------------------*
FORM FILL_FCAT  USING    P_FIELD
      P_COLPOS
      P_DESC_M

      .
  WA_FCAT-FIELDNAME = P_FIELD.
  WA_FCAT-COL_POS   = P_COLPOS.
  WA_FCAT-SELTEXT_M = P_DESC_M.
  WA_FCAT-TABNAME   = 'GT_FINAL'.
  IF P_FIELD+0(1) = 'V'.
    WA_FCAT-EMPHASIZE   = 'C100'.
  ENDIF.
  IF P_FIELD+0(1) = 'Q'.
    WA_FCAT-EMPHASIZE   = 'C700'.
  ENDIF.

  APPEND WA_FCAT TO IT_FCAT.
  CLEAR WA_FCAT.

ENDFORM.

