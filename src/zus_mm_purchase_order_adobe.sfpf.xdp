dge thickness="0.26mm"><color value=" 0, 0, 0"/></edge><edge thickness="0.26mm"><color value=" 0, 0, 0"/></edge></border></subform></subform><subform name="X2500_TEMPLATE6" layout="position"><occur min="1" max="1"/><keep intact="contentArea"/><subform name="cell-r1-c1" layout="lr-tb" x="0" y="0" w="19cm" h="2.75cm"><occur min="1" max="1"/><subform name="X2500_TEXT22" layout="lr-tb" w="19cm"><draw name="X2500_TEXT22" w="19cm"><value><exData contentType="text/html"><div xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-template/2.2/"><div style=" font-family : &apos;Times New Roman&apos; ; font-size : 9pt ; font-weight : bold ; line-height : 4.23mm ; text-decoration : none ; text-align : left ; margin-left : 1.50mm ; clear : both ;">Special Notes :</div><div style=" font-family : &apos;Times New Roman&apos; ; font-size : 8pt ; font-weight : normal ; line-height : 4.23mm ; text-decoration : none ; text-align : left ; margin-left : 1.01mm ; clear : both ;">&#160;</div><div style=" font-family : &apos;Times New Roman&apos; ; font-size : 8pt ; font-weight : normal ; line-height : 4.23mm ; text-decoration : none ; text-align : left ; margin-left : 1.01mm ; clear : both ;">1.Kindly maintain DelVal item codes and purchase order numbers on your invoice and packing list.</div><div style=" font-family : &apos;Times New Roman&apos; ; font-size : 8pt ; font-weight : normal ; line-height : 4.23mm ; text-decoration : none ; text-align : left ; margin-left : 1.01mm ; clear : both ;">2.In case of any discrepancies, please contact DelVal USA Office.If no response is received within the next 48 hours, we will consider this <span style="xfa-tab-count : 1  ;"/>accepted.</div><div style=" font-family : &apos;Times New Roman&apos; ; font-size : 8pt ; font-weight : normal ; line-height : 4.23mm ; text-decoration : none ; text-align : left ; margin-left : 1.01mm ; clear : both ;">3.This is an electronic PO copy. No signature is required.</div></div></exData></valu