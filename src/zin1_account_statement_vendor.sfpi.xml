    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS/>
     <OUTPUT_PARAMETERS/>
     <INITIALIZATION>
      <FPCLINE>Loop at IT_VENDORBAL INTO WA_VENDORBAL.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>TOTAL_DEBIT = 0.</FPCLINE>
      <FPCLINE>TOTAL_CREDIT = 0.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE name2 FROM lfa1 INTO wa_vendorbal-name2</FPCLINE>
      <FPCLINE>                      WHERE lifnr = wa_vendorbal-lifnr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_vendorBAL-HOUSE_NUM1</FPCLINE>
      <FPCLINE> WA_vendorBAL-STREET</FPCLINE>
      <FPCLINE> WA_VENDORBAL-str_suppl1</FPCLINE>
      <FPCLINE>  WA_VENDORBAL-str_suppl1 INTO lv_addr SEPARATED BY space.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONDENSE lv_addr.</FPCLINE>
      <FPCLINE>CONCATENATE WA_VENDORBAL-NAME1 WA_VENDORBAL-NAME2</FPCLINE>
      <FPCLINE>INTO lv_addr1 SEPARATED BY space.</FPCLINE>
      <FPCLINE>CONDENSE lv_addr1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>CONCATENATE WA_VENDORBAL-ORT02</FPCLINE>
      <FPCLINE>WA_VENDORBAL-ORT01 &apos;-&apos;</FPCLINE>
      <FPCLINE>WA_VENDORBAL-PSTLZ INTO lv_addr2 SEPARATED BY space.</FPCLINE>
      <FPCLINE>CONDENSE lv_addr2 .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF WA_VENDORBAL-CLBAL LT 0.</FPCLINE>
      <FPCLINE>WA_VENDORBAL-CLBAL = WA_VENDORBAL-CLBAL * -1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>LV_CR_DR = &apos;Cr&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>else.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>LV_CR_DR = &apos;Dr&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  ENDLOOP.</FPCLINE>
     </INITIALIZATION>
     <FORMS/>
