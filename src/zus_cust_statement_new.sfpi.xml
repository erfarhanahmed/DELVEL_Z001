      <FPPARAMETER>TOTAL1</FPPARAMETER>
      <FPPARAMETER>ITAB</FPPARAMETER>
      <FPPARAMETER>WA_T001W</FPPARAMETER>
      <FPPARAMETER>WA_ADRC</FPPARAMETER>
      <FPPARAMETER>WA_ADR6</FPPARAMETER>
      <FPPARAMETER>IT_ADR6</FPPARAMETER>
      <FPPARAMETER>EMAIL</FPPARAMETER>
      <FPPARAMETER>EMAIL1</FPPARAMETER>
      <FPPARAMETER>EMAIL2</FPPARAMETER>
      <FPPARAMETER>KUNNR</FPPARAMETER>
      <FPPARAMETER>ORIGINAL1</FPPARAMETER>
      <FPPARAMETER>WA_ITAB</FPPARAMETER>
      <FPPARAMETER>ORIGINAL</FPPARAMETER>
      <FPPARAMETER>MAIL</FPPARAMETER>
     </INPUT_PARAMETERS>
     <OUTPUT_PARAMETERS>
      <FPPARAMETER>WA_IT_ITAB</FPPARAMETER>
      <FPPARAMETER>IT_ITAB</FPPARAMETER>
      <FPPARAMETER>ITAB</FPPARAMETER>
      <FPPARAMETER>WA_ITAB</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE>*BREAK dvbasis.</FPCLINE>
      <FPCLINE>*it_itab = itab.</FPCLINE>
      <FPCLINE>*sort it_itab.</FPCLINE>
      <FPCLINE>*SORT itab.</FPCLINE>
      <FPCLINE>SELECT SINGLE * FROM t001w INTO wa_t001w</FPCLINE>
      <FPCLINE>  WHERE werks = &apos;US01&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE * FROM adrc INTO wa_adrc</FPCLINE>
      <FPCLINE>  WHERE ADDRNUMBER = wa_t001w-adrnr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*READ TABLE it_itab INTO wa_it_itab INDEX 1.</FPCLINE>
      <FPCLINE>READ TABLE itab INTO wa_itab INDEX 1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE * FROM kna1 INTO wa_kna1</FPCLINE>
      <FPCLINE>  WHERE kunnr = kunnr.&quot;wa_itab-kunnr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SELECT * FROM adr6 INTO TABLE it_adr6   &quot;addrnumber smtp_addr</FPCLINE>
      <FPCLINE>       WHERE addrnumber = wa_kna1-adrnr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>READ TABLE it_adr6 INTO wa_adr6 INDEX 1.</FPCLINE>
      <FPCLINE>IF sy-subrc = 0.</FPCLINE>
      <FPCLINE>email = wa_adr6-smtp_addr.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>READ TABLE it_adr6 INTO wa_adr6 INDEX 2.</FPCLINE>
      <FPCLINE>IF sy-subrc = 0.</FPCLINE>
      <FPCLINE>email1 = wa_adr6-smtp_addr.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>READ TABLE it_adr6 INTO wa_adr6 INDEX 3.</FPCLINE>
      <FPCLINE>IF sy-subrc = 0.</FPCLINE>
      <FPCLINE>email2 = wa_adr6-smtp_addr.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE email1 email2 INTO mail SEPARATED BY &apos;,&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*BREAK-POINT.</FPCLINE>
      <FPCLINE>*LOOP at itab into wa_itab.</FPCLINE>
      <FPCLINE>**********Cell11</FPCLINE>
      <FPCLINE>*ORIGINAL = wa_itab-debit.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>loop at itab into wa_itab.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*CLEAR : ORIGINAL,ORIGINAL1.</FPCLINE>
      <FPCLINE>*IF wa_itab-debit &lt; 0.</FPCLINE>
      <FPCLINE>*  wa_itab-ORIGINAL = wa_itab-debit * -1.</FPCLINE>
      <FPCLINE>**CONCATENATE &apos;(&apos; ORIGINAL &apos;)&apos; INTO ORIGINAL.</FPCLINE>
      <FPCLINE>*ELSE.</FPCLINE>
      <FPCLINE>*  wa_itab-ORIGINAL = wa_itab-debit.</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>**********Cell12</FPCLINE>
      <FPCLINE>*BREAK-POINT.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_tot = gv_tot + wa_itab-netbal .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_tot0_30 = gv_tot0_30 + wa_itab-NETB30 + wa_itab-NETB60 .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_tot31_60 = gv_tot31_60 + wa_itab-NETB90 .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_tot61_90 = gv_tot61_90 + wa_itab-NETB120.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>gv_totall = gv_totall + wa_itab-NETB180 + wa_itab-NETB360 + wa_itab-NETB720 + wa_itab-NETB1000.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>**TOTAL = WA_ITAB-netbal.</FPCLINE>
      <FPCLINE>*CLEAR: TOTAL, TOTAL1.</FPCLINE>
      <FPCLINE>*</FPCLINE>
      <FPCLINE>*IF wa_itab-netbal &lt; 0.</FPCLINE>
      <FPCLINE>*  TOTAL = wa_itab-netbal * -1.</FPCLINE>
      <FPCLINE>**CONCATENATE &apos;(&apos; TOTAL &apos;)&apos; INTO TOTAL.</FPCLINE>
      <FPCLINE>*ELSE.</FPCLINE>
      <FPCLINE>*  TOTAL = wa_itab-netbal.</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>Endloop.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*IF gv_tot31_60 &lt; 0.</FPCLINE>
      <FPCLINE>*  gv_tot31_60_disp = |{ gv_tot31_60 * -1 } -|.</FPCLINE>
      <FPCLINE>*ELSE.</FPCLINE>
      <FPCLINE>*  gv_tot31_60_disp = |{ gv_tot31_60 }|.</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE>*</FPCLINE>
      <FPCLINE>Data : lv_temp TYPE char20.</FPCLINE>
      <FPCLINE>IF gv_tot31_60 &lt; 0.</FPCLINE>
      <FPCLINE>  gv_tot31_60_new = gv_tot31_60 * -1.</FPCLINE>
      <FPCLINE>  WRITE gv_tot31_60_new TO lv_temp CURRENCY &apos; INR&apos;.</FPCLINE>
      <FPCLINE>          CONDENSE lv_temp NO-GAPS.</FPCLINE>
      <FPCLINE>  gv_tot31_60_disp = |{ lv_temp } -|.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  gv_tot31_60_disp = |{ gv_tot31_60 }|.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*DATA(lv_temp) = gv_tot31_60.</FPCLINE>
      <FPCLINE>*</FPCLINE>
      <FPCLINE>*IF lv_temp &lt; 0.</FPCLINE>
      <FPCLINE>*  lv_temp = lv_temp * -1.</FPCLINE>
      <FPCLINE>*  WRITE lv_temp TO gv_tot31_60_disp CURRENCY &apos;INR&apos;. &quot;or your currency key</FPCLINE>
      <FPCLINE>*  CONDENSE lv_temp NO-GAPS.</FPCLINE>
      <FPCLINE>*  CONCATENATE gv_tot31_60_disp &apos;-&apos; INTO gv_tot31_60_disp.</FPCLINE>
      <FPCLINE>*ELSE.</FPCLINE>
      <FPCLINE>*  WRITE lv_temp TO gv_tot31_60_disp CURRENCY &apos;INR&apos;.</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE/>
     </INITIALIZATION>
     <FORMS/>
