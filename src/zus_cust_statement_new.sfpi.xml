    </CL_FP_INTERFACE_DATA_CHANGED>
    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS>
      <FPPARAMETER>GV_TOT</FPPARAMETER>
      <FPPARAMETER>GV_TOT0_30</FPPARAMETER>
      <FPPARAMETER>GV_TOT31_60</FPPARAMETER>
      <FPPARAMETER>GV_TOT61_90</FPPARAMETER>
      <FPPARAMETER>GV_TOTALL</FPPARAMETER>
