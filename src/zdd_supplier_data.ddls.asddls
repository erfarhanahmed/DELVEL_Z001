  A._SupplierToBusinessPartner,
  A._UniformResourceIdentifier,
  B.j_1issist,
  case B.j_1issist
  when  '1' then 'Micro'
  when  '2' then 'Small'
  when  '3' then 'Medium'
  when  '4' then 'NA'
  else  '9'
  end as j_1issist_DESC
  
}
