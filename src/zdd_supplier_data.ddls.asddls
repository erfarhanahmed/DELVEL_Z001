  A.TaxInvoiceRepresentativeName,
  A.IndustryType,
  A.IN_GSTSupplierClassification,
  A.SuplrProofOfDelivRlvtCode,
  A.TradingPartner,
  A.BR_TaxIsSplit,
  A.AU_PayerIsPayingToCarryOnEnt,
  A.AU_IndividualIsUnder18,
  A.AU_PaymentIsExceeding75,
  A.AU_PaymentIsWhollyInputTaxed,
  A.AU_PartnerIsSupplyWithoutGain,
  A.AU_SupplierIsEntitledToABN,
  A.AU_PaymentIsIncomeExempted,
  A.AU_SupplyIsMadeAsPrivateHobby,
  A.AU_SupplyMadeIsOfDmstcNature,
  A.IsToBeAcceptedAtOrigin,
  A.BPIsEqualizationTaxSubject,
