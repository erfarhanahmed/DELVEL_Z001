  A.AccountIsBlockedForPosting,
  A.TaxJurisdiction,
  A.SupplierStandardCarrierAccess,
  A.SupplierFwdAgentFreightGroup,
  A.SupplierAgentProcedureGroup,
  A.SupplIsSocialInsuranceRegtrd,
  A.SocialInsuranceActivityCode,
