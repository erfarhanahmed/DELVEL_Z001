  A.Country,
  A.ConcatenatedInternationalLocNo,
  A.SupplierProcurementBlock,
  A.SuplrQualityManagementSystem,
  A.SuplrQltyInProcmtCertfnValidTo,
  A.SupplierLanguage,
  A.AlternativePayeeAccountNumber,
  A.PhoneNumber1,
  A.FaxNumber,
  A.IsNaturalPerson,
  A.TaxNumberResponsible,
  A.UK_ContractorBusinessType,
  A.UK_PartnerTradingName,
  A.UK_PartnerTaxReference,
  A.UK_VerificationStatus,
  A.UK_VerificationNumber,
  A.UK_CompanyRegistrationNumber,
