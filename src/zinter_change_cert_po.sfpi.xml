   <cls:CL_FP_CODING id="o5">
    <CL_FP_INTERFACE_DATA_CHANGED classVersion="1">
     <INTERFACE_DATA href="#o1"/>
    </CL_FP_INTERFACE_DATA_CHANGED>
    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS>
      <FPPARAMETER>WA_FINAL-MATNR</FPPARAMETER>
      <FPPARAMETER>WA_FINAL</FPPARAMETER>
     </INPUT_PARAMETERS>
     <OUTPUT_PARAMETERS>
      <FPPARAMETER>GV_TEXT</FPPARAMETER>
      <FPPARAMETER>LV_FLAG</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE/>
      <FPCLINE>DATA : lv_lgort TYPE lgort_d.</FPCLINE>
      <FPCLINE>*BREAK-POINT.</FPCLINE>
      <FPCLINE>SELECT SINGLE lgort</FPCLINE>
      <FPCLINE>               FROM vbap</FPCLINE>
      <FPCLINE>               INTO lv_lgort</FPCLINE>
      <FPCLINE>               WHERE vbeln = wa_final-vbeln</FPCLINE>
      <FPCLINE>               AND posnr = wa_final-vbelp.</FPCLINE>
      <FPCLINE>IF lv_lgort IS NOT INITIAL.</FPCLINE>
      <FPCLINE>  IF lv_lgort(1) = &apos;K&apos;.</FPCLINE>
      <FPCLINE>    lv_flag = abap_true.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>DATA:</FPCLINE>
      <FPCLINE>    lv_id        TYPE thead-tdname,</FPCLINE>
      <FPCLINE>    lt_lines     TYPE STANDARD TABLE OF tline,</FPCLINE>
      <FPCLINE>    ls_lines     TYPE tline.</FPCLINE>
      <FPCLINE> lv_id = wa_final-matnr.</FPCLINE>
      <FPCLINE> DATA(lo_text_reader) = NEW zcl_read_text( ).</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CLEAR: lt_lines,ls_lines.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>lo_text_reader-&gt;read_text_string( EXPORTING id = &apos;GRUN&apos; name = lv_id object = &apos;MATERIAL&apos; IMPORTING lv_lines = DATA(lv_lines1) ).</FPCLINE>
      <FPCLINE>gv_text = lv_lines1.</FPCLINE>
      <FPCLINE>CONDENSE gv_text.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>**    CALL FUNCTION &apos;READ_TEXT&apos;</FPCLINE>
      <FPCLINE>**      EXPORTING</FPCLINE>
      <FPCLINE>**        client                  = sy-mandt</FPCLINE>
      <FPCLINE>**        id                      = &apos;GRUN&apos;</FPCLINE>
      <FPCLINE>**        language                = sy-langu</FPCLINE>
      <FPCLINE>**        name                    = lv_id</FPCLINE>
      <FPCLINE>**        object                  = &apos;MATERIAL&apos;</FPCLINE>
      <FPCLINE>**      TABLES</FPCLINE>
      <FPCLINE>**        lines                   = lt_lines</FPCLINE>
      <FPCLINE>**      EXCEPTIONS</FPCLINE>
      <FPCLINE>**        id                      = 1</FPCLINE>
      <FPCLINE>**        language                = 2</FPCLINE>
      <FPCLINE>**        name                    = 3</FPCLINE>
      <FPCLINE>**        not_found               = 4</FPCLINE>
      <FPCLINE>**        object                  = 5</FPCLINE>
      <FPCLINE>**        reference_check         = 6</FPCLINE>
      <FPCLINE>**        wrong_access_to_archive = 7</FPCLINE>
      <FPCLINE>**        OTHERS                  = 8.</FPCLINE>
      <FPCLINE>**    IF sy-subrc &lt;&gt; 0.</FPCLINE>
      <FPCLINE>*** Implement suitable error handling here</FPCLINE>
      <FPCLINE>**    ENDIF.</FPCLINE>
      <FPCLINE>**    IF NOT lt_lines IS INITIAL.</FPCLINE>
      <FPCLINE>**      LOOP AT lt_lines INTO ls_lines.</FPCLINE>
      <FPCLINE>**        IF NOT ls_lines-tdline IS INITIAL.</FPCLINE>
      <FPCLINE>**          CONCATENATE gv_text ls_lines-tdline INTO gv_text SEPARATED BY space.</FPCLINE>
      <FPCLINE>**        ENDIF.</FPCLINE>
      <FPCLINE>**      ENDLOOP.</FPCLINE>
      <FPCLINE>**      CONDENSE gv_text.</FPCLINE>
      <FPCLINE>**    ENDIF.</FPCLINE>
      <FPCLINE/>
     </INITIALIZATION>
