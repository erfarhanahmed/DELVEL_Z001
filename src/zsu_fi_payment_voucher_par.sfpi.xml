      <FPCLINE/>
      <FPCLINE>DATA:str TYPE char255.</FPCLINE>
      <FPCLINE>*BREAK-POINT.</FPCLINE>
      <FPCLINE>str = &apos;شركة دلفال فلو كونترولز الشرق الأوسط المحدودة&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>lv_invno = REVERSE( str ).</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>  LV_AMOUNT = WA_FINAL1-AMOUNT.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>loop AT IT_BSIK1 INTO WA_BSIK1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_total = gv_total + WA_BSIK1-DMBTR.</FPCLINE>
      <FPCLINE/>
