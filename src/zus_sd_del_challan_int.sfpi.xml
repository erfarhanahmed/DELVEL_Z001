      <FPCLINE>**</FPCLINE>
      <FPCLINE>** IF LV_LATRS EQ &apos; &apos;.</FPCLINE>
      <FPCLINE>**            CONCATENATE LV_LINE LV_LATRS1 INTO LV_LINE SEPARATED BY &apos; &apos;.</FPCLINE>
      <FPCLINE>**          ELSE.</FPCLINE>
      <FPCLINE>**            CONCATENATE LV_LINE LV_LATRS1 INTO LV_LINE.</FPCLINE>
      <FPCLINE>**          ENDIF.</FPCLINE>
      <FPCLINE>**        ENDIF.</FPCLINE>
      <FPCLINE>**      ENDDO.</FPCLINE>
      <FPCLINE>**</FPCLINE>
      <FPCLINE>**IF LV_LINE IS NOT INITIAL.</FPCLINE>
      <FPCLINE>**        CLEAR: WA_LINES-TDLINE.</FPCLINE>
      <FPCLINE>**        WA_LINES-TDLINE = LV_LINE.</FPCLINE>
      <FPCLINE>**      ENDIF.</FPCLINE>
      <FPCLINE>**</FPCLINE>
