      <FPCLINE/>
      <FPCLINE>READ TABLE it_vbap1 INTO wa_vbap1 with key vbeln = wa_vbfa-vbelv</FPCLINE>
      <FPCLINE>                                           posnr = wa_lips-posnr.</FPCLINE>
      <FPCLINE>  IF  sy-subrc  = 0.</FPCLINE>
      <FPCLINE>  wa_final-kwmeng   = wa_vbap1-kwmeng .</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>append wa_final to it_final.</FPCLINE>
      <FPCLINE>clear : wa_final.</FPCLINE>
