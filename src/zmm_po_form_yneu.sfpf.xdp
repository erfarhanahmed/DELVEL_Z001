            <subform layout="tb" name="Discl." w="190.5mm">
               <bind match="none"/>
               <draw minH="7.62mm" name="Text5" w="190.5mm">
                  <ui>
                     <textEdit/>
                  </ui>
                  <value>
                     <exData contentType="text/html" xliff:rid="A83FB6F8-4219-48B9-A5F7-067550DC57F4">
                        <body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/"><p style="letter-spacing:0in">Disclaimer</p><p style="letter-spacing:0in">*<span style="font-weight:normal">Taxes may be charged as applicable under the relevant statute and rules applicable as on the date of Invoice.</span></p><p style="text-valign:top;letter-spacing:0in">*<span style="font-weight:normal">Any liability including reversal of credit,interest or penalty arising on the company due to incorrect statutory information communicated via the invoice</span></p><p style="text-valign:top;font-weight:normal;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span>or otherwise by the vendor, will be passed on to the vendor.This includes inter alia, information regarding HSN/ SAC, rate of tax used and other</p><p style="text-valign:top;font-weight:normal;letter-spacing:0in"><span style="xfa-spacerun:yes"> </span>mandatory fields as required under the Goods &amp; Service Tax Law.</p><p style="text-valign:top;letter-spacing:0in">*<span style="font-weight:normal">The Company retains the right to process the payment of the tax amount collected under the Goods &amp; Service Tax Law only upon the successful</span></p><p style="margin-left:2.88pt;text-valign:top;font-weight:normal;letter-spacing:0in">matching of the relevant information uploaded on the ASP/ GSP. The general terms of payment which have been negotiated for this Purchase Order<span style="xfa-spacerun:yes">               </span>will not apply to the amount of taxes collected under the Goods &amp; Service Tax Law.</p><p style="text-valign:top;font-weight:normal;letter-spacing:0in">*W.r.t this Purchase order any dispute shall be resolved at satara Jurisdiction only.</p><p style="text-valign:top;font-weight:normal;letter-spacing:0in">*Goods/services provider shall ensure fulfillment of all applicable legal requirement For goods/services supplied by them.</p><p style="text-valign:top;font-weight:normal;letter-spacing:0in">*Goods/services provider shall ensure valid consent of Pollution control Board of their respective state.</p></body>
                     </exData>
                  </value>
                  <font baselineShift="0pt" size="8pt" typeface="Arial" weight="bold"/>
                  <margin bottomInset="0.5mm" leftInset="0.5mm" rightInset="0.5mm" topInset="0.5mm"/>
                  <para marginLeft="1.44pt" marginRight="0pt" spaceAbove="0pt" spaceBelow="0pt" textIndent="0pt" vAlign="middle"/>
                  <border>
                     <edge presence="hidden"/>
                     <corner presence="hidden"/>
                     <corner presence="hidden"/>
                     <corner/>
                     <corner presence="hidden"/>
                  </border>
               </draw>
               <?templateDesigner expand 0?>
               <event activity="initialize" name="event__initialize">
                  <script contentType="application/x-javascript">if (LS_DIS.rawValue == "X") {
      this.presence = "hidden";
} 


</script>
               </event>
            </subform>
