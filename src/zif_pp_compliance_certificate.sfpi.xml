   <cls:CL_FP_CODING id="o5">
    <CL_FP_INTERFACE_DATA_CHANGED classVersion="1">
     <INTERFACE_DATA href="#o1"/>
    </CL_FP_INTERFACE_DATA_CHANGED>
    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS>
      <FPPARAMETER>IT_FINAL</FPPARAMETER>
     </INPUT_PARAMETERS>
     <OUTPUT_PARAMETERS>
      <FPPARAMETER>WA_FINAL</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE>DATA(lo_text_reader) = NEW zcl_read_text( ).</FPCLINE>
      <FPCLINE/>
      <FPCLINE>LOOP AT IT_FINAL INTO WA_FINAL.</FPCLINE>
      <FPCLINE>V_QTY = WA_FINAL-LFIMG.</FPCLINE>
      <FPCLINE>CONDENSE V_QTY.</FPCLINE>
      <FPCLINE>ENDLOOP.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>SELECT SINGLE * FROM VBAK INTO WA_VBAK</FPCLINE>
      <FPCLINE>  WHERE VBELN = wa_final-vbelv.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>DATA: lv_name   TYPE thead-tdname.</FPCLINE>
      <FPCLINE>  CLEAR: it_lines,wa_LINES.</FPCLINE>
      <FPCLINE>      REFRESH it_lines.</FPCLINE>
      <FPCLINE>CONCATENATE wa_vbak-vbeln wa_final-posnr INTO lv_name.</FPCLINE>
      <FPCLINE>*      CALL FUNCTION &apos;READ_TEXT&apos;</FPCLINE>
      <FPCLINE>*        EXPORTING</FPCLINE>
      <FPCLINE>*          client                  = sy-mandt</FPCLINE>
      <FPCLINE>*          id                      = &apos;0001&apos;</FPCLINE>
      <FPCLINE>*          language                = sy-langu</FPCLINE>
      <FPCLINE>*          name                    = lv_name</FPCLINE>
      <FPCLINE>*          object                  = &apos;VBBP&apos;</FPCLINE>
      <FPCLINE>*        TABLES</FPCLINE>
      <FPCLINE>*          lines                   = it_lines</FPCLINE>
      <FPCLINE>*        EXCEPTIONS</FPCLINE>
      <FPCLINE>*          id                      = 1</FPCLINE>
      <FPCLINE>*          language                = 2</FPCLINE>
      <FPCLINE>*          name                    = 3</FPCLINE>
      <FPCLINE>*          not_found               = 4</FPCLINE>
      <FPCLINE>*          object                  = 5</FPCLINE>
      <FPCLINE>*          reference_check         = 6</FPCLINE>
      <FPCLINE>*          wrong_access_to_archive = 7</FPCLINE>
      <FPCLINE>*          OTHERS                  = 8.</FPCLINE>
      <FPCLINE>*      IF sy-subrc &lt;&gt; 0.</FPCLINE>
      <FPCLINE>** MESSAGE ID SY-MSGID TYPE SY-MSGTY NUMBER SY-MSGNO</FPCLINE>
      <FPCLINE>**         WITH SY-MSGV1 SY-MSGV2 SY-MSGV3 SY-MSGV4.</FPCLINE>
      <FPCLINE>*      ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*IF it_lines IS NOT INITIAL.</FPCLINE>
      <FPCLINE>**LOOP AT it_lines INTO wa_lines.</FPCLINE>
      <FPCLINE>*READ TABLE it_lines INTO wa_lines INDEX 1.</FPCLINE>
      <FPCLINE>*IF NOT wa_lines-tdline IS INITIAL.</FPCLINE>
      <FPCLINE>*  PO_NO = wa_lines-tdline.</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE>*</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE>lo_text_reader-&gt;read_text_string( EXPORTING id = &apos;0001&apos; name = LV_NAME object = &apos;VBBP&apos; IMPORTING lv_lines = DATA(lv_lines1) ).</FPCLINE>
      <FPCLINE>PO_NO = lv_lines1.</FPCLINE>
      <FPCLINE>CLEAR LV_CUST.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF WA_VBAK-KUNNR = &apos;0000300000&apos;.</FPCLINE>
      <FPCLINE>LV_CUST = PO_NO.</FPCLINE>
      <FPCLINE>ELSEIF WA_VBAK-KUNNR ne &apos;0000300000&apos;.</FPCLINE>
      <FPCLINE>LV_CUST = WA_FINAL-BSTNK.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>LV_INDIA = &apos;(INDIA)&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>***********************************************************************************</FPCLINE>
      <FPCLINE>clear: lv_lines1.</FPCLINE>
      <FPCLINE>DATA: lv_textname TYPE thead-tdname,</FPCLINE>
      <FPCLINE>     lv_text     TYPE string,</FPCLINE>
      <FPCLINE>     lt_lines    TYPE TABLE OF tline,</FPCLINE>
      <FPCLINE>     ls_line     TYPE tline.</FPCLINE>
      <FPCLINE>lv_textname =  WA_FINAL-MATNR.</FPCLINE>
      <FPCLINE>*BREAK DVBASIS.</FPCLINE>
      <FPCLINE>*CALL FUNCTION &apos;READ_TEXT&apos;</FPCLINE>
      <FPCLINE>* EXPORTING</FPCLINE>
      <FPCLINE>*   id       = &apos;GRUN&apos;         &quot;</FPCLINE>
      <FPCLINE>*   language = sy-langu</FPCLINE>
      <FPCLINE>*   name     = lv_textname</FPCLINE>
      <FPCLINE>*   object   = &apos;MATERIAL&apos;</FPCLINE>
      <FPCLINE>* TABLES</FPCLINE>
      <FPCLINE>*   lines    = lt_lines</FPCLINE>
      <FPCLINE>* EXCEPTIONS</FPCLINE>
      <FPCLINE>*   not_found = 1</FPCLINE>
      <FPCLINE>*   others    = 2.</FPCLINE>
      <FPCLINE>*IF sy-subrc = 0.</FPCLINE>
      <FPCLINE>* LOOP AT lt_lines INTO ls_line.</FPCLINE>
      <FPCLINE>*   CONCATENATE lv_text ls_line-tdline INTO lv_text SEPARATED BY space.</FPCLINE>
      <FPCLINE>* ENDLOOP.</FPCLINE>
      <FPCLINE>* LV_REC = lv_text.</FPCLINE>
      <FPCLINE>*ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>lo_text_reader-&gt;read_text_string( EXPORTING id = &apos;GRUN&apos; name = lv_textname object = &apos;MATERIAL&apos; IMPORTING lv_lines = lv_lines1 ).</FPCLINE>
      <FPCLINE>LV_REC = lv_lines1.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
     </INITIALIZATION>
     <FORMS/>
    </CL_FP_CODING>
