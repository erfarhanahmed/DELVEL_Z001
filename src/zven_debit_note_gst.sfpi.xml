      <FPCLINE/>
      <FPCLINE>  DATA :  TEXT_LINES TYPE TABLE OF TLINE,</FPCLINE>
      <FPCLINE>          WA_TEXT_LINE TYPE TLINE.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>DATA(lo_text_reader) = NEW zcl_read_text( ).</FPCLINE>
